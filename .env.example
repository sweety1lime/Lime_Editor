# Скопируй в .env (.env в .gitignore) и заполни значения перед `docker compose -f compose.prod.yml up`.

DOMAIN=lime.example.com

POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=limeeditor

# Образ приложения. Собирается GitHub Actions и пушится в GHCR при push в master.
APP_IMAGE=ghcr.io/sweety1lime/lime_editor:latest

# Reverse proxy headers. In the bundled compose setup, app is not published to the host
# and Caddy is the only public entry point, so trusting all forwarded headers is explicit.
# For a deployment where Kestrel is directly reachable, set this to false and fill one of:
#   FORWARDED_HEADERS_KNOWN_PROXIES=10.0.0.10
#   FORWARDED_HEADERS_KNOWN_NETWORKS=172.16.0.0/12
FORWARDED_HEADERS_TRUST_ALL=true
FORWARDED_HEADERS_KNOWN_PROXIES=
FORWARDED_HEADERS_KNOWN_NETWORKS=

# Бэкапы (сайдкар backup в compose.prod.yml). pg_dump + архив медиа в volume backups_data.
# Восстановление и off-site-синк — см. ops/backup/RESTORE.md.
#   BACKUP_INTERVAL       — период бэкапа в секундах (по умолчанию 86400 = сутки)
#   BACKUP_RETENTION_DAYS — сколько дней хранить дампы (по умолчанию 14)
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=14

# AI-генерация (этап 2). OpenAI-совместимый агрегатор, доступный из РФ (оплата рублями):
#   VseGPT:  AI_BASE_URL=https://api.vsegpt.ru/v1
#   ProxyAPI: AI_BASE_URL=https://api.proxyapi.ru/openai/v1
# Модель задаётся в appsettings (Ai:Model), напр. anthropic/claude-haiku-4-5 или deepseek/deepseek-chat.
# Без AI_API_KEY функции AI просто выключены (кнопки сообщают «не настроено»).
AI_BASE_URL=https://api.vsegpt.ru/v1
AI_API_KEY=

# Фотосток в медиа-пикере (Фаза 1). Бесплатный ключ Pexels: https://www.pexels.com/api/
# Без него вкладка «Сток» показывает подсказку, остальное работает.
STOCK_PEXELS_KEY=

# Почта (восстановление пароля). Без SMTP_HOST/SMTP_FROM письма не уходят, а логируются
# (forgot-password всё равно работает в dev). Для прода задай реальный SMTP-провайдер.
#   SMTP_PORT по умолчанию 587, SMTP_SSL по умолчанию true (STARTTLS).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@lime.example.com
SMTP_SSL=true

# В проде включай true после настройки SMTP_*, чтобы новый/измененный email реально подтверждался письмом.
IDENTITY_REQUIRE_CONFIRMED_EMAIL=false

# GitHub-деплой (Wave 1 п.4): «задеплоить сайт в свой GitHub-репозиторий» одной кнопкой.
# Нужно зарегистрировать OAuth App: https://github.com/settings/developers →
#   Authorization callback URL: https://${DOMAIN}/GitHub/OAuthCallback
# Без ключей кнопка честно сообщает «не настроено», остальное приложение не затронуто.
# (Ключи DataProtection, которыми шифруются пользовательские GitHub-токены, персистятся
#  на volume dataprotection_keys — см. compose.prod.yml, ничего настраивать не нужно.)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Бета-режим (по умолчанию ВКЛ): Free-пользователи получают лимиты Pro — экспорт кода,
# GitHub-деплой, кастомный код, AI-квота 300/мес, 25 сайтов. Биллинг заморожен (M3),
# поэтому без флага Pro-фичи в проде недоступны никому. Платные подписки флаг не трогает.
# При запуске биллинга выставить false.
BETA_UNLOCK_PRO=true

# Скриншот-превью публикаций: после publish фоновый воркер рендерит /u/... headless-Chromium'ом
# в /media/previews/{id}.png и подставляет в карточки MySites/галереи + og:image.
# В проде требует Chromium в образе (playwright install --with-deps chromium) — пока его нет,
# держи false (без браузера рендер и сам мягко выключится, но зачем зря грузить воркер).
# В dev включено по умолчанию: браузеры Playwright уже стоят ради e2e-тестов.
PREVIEW_ENABLED=false
