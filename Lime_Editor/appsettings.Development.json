{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  // Локальная разработка ходит по localhost/127.0.0.1/произвольным хостам (dev-туннели и т.п.) —
  // в dev allow-list не ограничиваем. В проде действует строгий дефолт из appsettings.json + env.
  "AllowedHosts": "*",
  // E2E-спеки регистрируют свежего юзера на файл; повторные прогоны подряд с одним живым
  // сервером выедали прод-лимит 10/мин. В dev — с запасом; прод-дефолт живёт в Startup.
  "RateLimits": {
    "AuthPerMinute": 200
  }
}
