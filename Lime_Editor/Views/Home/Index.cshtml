@model IList<Lime_Editor.Models.Template>
@{
    ViewData["Title"] = "Lime — Конструктор сайтов без кода";
    var templates = (Model ?? new List<Lime_Editor.Models.Template>())
        .Where(t => t.IdTemplate != 4)
        .ToList();
}

<!-- HERO -->
<section class="lime-hero lime-container">
    <div class="lime-hero__eyebrow reveal"><span class="lime-hero__dot"></span> No code. <b>Just creativity.</b></div>
    <h1 class="reveal" data-delay="1">Сайт, как ты задумал.<br><span class="lime-hero__grad">Без кода. Без границ.</span></h1>
    <p class="lime-hero__sub reveal" data-delay="2">Опиши идею словами — и смотри, как Lime собирает лендинг на твоих глазах. Перетаскивай блоки, меняй всё на лету, публикуй в один клик.</p>
    <div class="lime-hero__ctas reveal" data-delay="3">
        <a class="lime-btn lime-btn--primary lime-btn--lg" href="/Home/SignUp">Начать бесплатно →</a>
        <a class="lime-btn lime-btn--ghost lime-btn--lg" href="/Home/EditDoc">Открыть редактор</a>
    </div>
    <div class="lime-hero__pills reveal" data-delay="4">
        <span class="lime-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg> Без карты</span>
        <span class="lime-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg> Бесплатный план</span>
        <span class="lime-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg> Публикация в 1 клик</span>
    </div>

    <!-- LIVE EDITOR MOCKUP -->
    <div class="lime-mockup reveal" data-delay="2" aria-hidden="true">
        <div class="lime-mockup__glow"></div>
        <div class="lime-mockup__bar">
            <span class="lime-mockup__cdot" style="background:#ff5f57"></span>
            <span class="lime-mockup__cdot" style="background:#febc2e"></span>
            <span class="lime-mockup__cdot" style="background:#28c840"></span>
            <span class="lime-mockup__url">lime.app/editor — Зерно</span>
        </div>
        <div class="lime-mockup__body">
            <div class="lime-mockup__rail">
                <div class="lime-mockup__rail-t">Блоки</div>
                <div class="lime-mockup__chip is-active"><span class="lime-mockup__chip-ico"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 14l4-3 4 3 3-2 7 4" stroke="currentColor" stroke-width="1.6"/></svg></span> Обложка</div>
                <div class="lime-mockup__chip"><span class="lime-mockup__chip-ico"><svg viewBox="0 0 24 24" fill="none"><path d="M5 7h14M5 12h14M5 17h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span> Текст</div>
                <div class="lime-mockup__chip"><span class="lime-mockup__chip-ico"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="5" height="14" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="9.5" y="5" width="5" height="14" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="16" y="5" width="5" height="14" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg></span> Фичи</div>
                <div class="lime-mockup__chip"><span class="lime-mockup__chip-ico"><svg viewBox="0 0 24 24" fill="none"><path d="M4 19V11M9.3 19V5M14.6 19v-6M20 19V8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span> Цифры</div>
                <div class="lime-mockup__chip"><span class="lime-mockup__chip-ico"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="8" height="16" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="13" y="4" width="8" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="13" y="13" width="8" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/></svg></span> Галерея</div>
            </div>
            <div class="lime-mockup__canvas">
                <div style="font-size:13px;color:var(--lime);font-weight:600;">Микро-обжарка · Москва</div>
                <div class="lime-mockup__h" data-typeloop='["Кофе, обжаренный сегодня утром","Свежесть, которую слышно","Зерно прямо с фермы"]'></div>
                <div class="lime-mockup__p">Маленькие партии, обжарка под каждый сорт и доставка в день заказа — пока аромат на пике.</div>
                <div class="lime-mockup__btns">
                    <span class="lime-btn lime-btn--primary lime-btn--sm" style="pointer-events:none">Собрать вкус</span>
                    <span class="lime-btn lime-btn--ghost lime-btn--sm" style="pointer-events:none">Смотреть сорта</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="lime-section lime-container" id="features">
    <div class="lime-section__head reveal">
        <div class="lime-eyebrow">Почему Lime</div>
        <h2 class="lime-section__title">Всё для запуска — <em class="display" style="font-style:italic;color:var(--lime)">без обучения</em></h2>
        <p class="lime-section__lead">От первой идеи до опубликованного сайта за минуты. Без кода, без дизайнера, без головной боли.</p>
    </div>
    <div class="lime-features">
        <div class="lime-feature reveal" data-delay="1">
            <div class="lime-feature__ico"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z" fill="currentColor"/></svg></div>
            <h3>AI собирает первый вариант</h3>
            <p>Опиши сайт одним предложением — Lime подберёт структуру, палитру и тексты, а блоки появятся прямо на холсте.</p>
        </div>
        <div class="lime-feature reveal" data-delay="2">
            <div class="lime-feature__ico"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></div>
            <h3>Drag &amp; drop + адаптив</h3>
            <p>Перетаскивай блоки, редактируй прямо в превью. Проверяй desktop, планшет и телефон в один клик.</p>
        </div>
        <div class="lime-feature reveal" data-delay="3">
            <div class="lime-feature__ico"><svg viewBox="0 0 24 24" fill="none"><path d="M5 12l5-9 5 9M4 12s2 8 6 8 6-8 6-8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="12" r="1.4" fill="currentColor"/></svg></div>
            <h3>Публикация в один клик</h3>
            <p>Жми «Опубликовать» — и сайт живёт по адресу /u/имя/слаг. Или скачай готовый ZIP и размести где угодно.</p>
        </div>
    </div>
</section>

<!-- TEMPLATES -->
<section class="lime-section lime-container" id="templates" style="padding-top:0;">
    <div class="lime-section__head reveal">
        <div class="lime-eyebrow">Шаблоны</div>
        <h2 class="lime-section__title">Старт за секунду</h2>
        <p class="lime-section__lead">Выбери точку отсчёта — каждый шаблон полностью редактируется в конструкторе.</p>
    </div>
    <div class="lime-tpl-grid">
        @{ var li = 0; }
        @foreach (var t in templates)
        {
            <a class="lime-tpl reveal" data-delay="@((li++ % 3) + 1)" href="/Home/SignUp">
                <div class="lime-tpl__preview">
                    @if (!string.IsNullOrEmpty(t.FolderPreview))
                    {
                        <img src="@t.FolderPreview" alt="@t.Name" loading="lazy">
                    }
                    else
                    {
                        <div class="lime-shot lime-shot-@(((li) % 6) + 1)"><div class="lime-shot__ui"><div class="lime-shot__bar" style="width:56%"></div><div class="lime-shot__bar dim" style="width:78%"></div><div class="lime-shot__chip"></div><div class="lime-shot__row"><div class="lime-shot__sq"></div><div class="lime-shot__sq"></div><div class="lime-shot__sq"></div></div></div></div>
                    }
                    <span class="lime-tpl__tag lime-badge lime-badge--muted">Шаблон</span>
                </div>
                <div class="lime-tpl__body">
                    <div><div class="lime-tpl__name">@t.Name</div><div class="lime-tpl__type">Готовый шаблон</div></div>
                    <span class="lime-btn lime-btn--soft lime-btn--sm">Открыть →</span>
                </div>
            </a>
        }
    </div>
</section>

<!-- FINAL CTA -->
<section class="lime-section lime-container" style="padding-top:0;">
    <div class="lime-finalcta reveal">
        <div class="lime-finalcta__glow"></div>
        <div class="lime-finalcta__inner">
            <h2>Готов запустить <em>свой</em> сайт?</h2>
            <p>Регистрация занимает 30 секунд. Без карты, без обязательств.</p>
            <a class="lime-btn lime-btn--primary lime-btn--lg" href="/Home/SignUp">Создать аккаунт →</a>
        </div>
    </div>
</section>
