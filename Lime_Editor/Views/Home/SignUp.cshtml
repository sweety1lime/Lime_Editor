@model Lime_Editor.Models.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<section class="lime-auth">
    <div class="lime-auth__split reveal">
        <!-- form -->
        <div class="lime-auth__form-side">
            <h1 class="lime-auth__title display">Создай аккаунт</h1>
            <p class="lime-auth__subtitle">30 секунд — и можно начинать собирать сайты.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                var allErrors = ViewData.ModelState
                    .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                    .Where(s => !string.IsNullOrEmpty(s))
                    .ToList();
                if (allErrors.Count > 0)
                {
                    <div class="lime-alert lime-alert--danger lime-mb-4">
                        <ul style="margin:0; padding-left: 1.2em;">
                            @foreach (var e in allErrors)
                            {
                                <li>@e</li>
                            }
                        </ul>
                    </div>
                }
            }

            <form asp-action="SignUp" asp-controller="Home" method="post" autocomplete="off">
                <div class="lime-field">
                    <label asp-for="Email" class="lime-label">Email</label>
                    <input asp-for="Email" class="lime-input" type="email" required placeholder="you@example.com">
                    <span asp-validation-for="Email" class="lime-validation"></span>
                </div>

                <div class="lime-field">
                    <label asp-for="Login" class="lime-label">Логин</label>
                    <input asp-for="Login" class="lime-input" type="text" required pattern="@UserNamePolicy.HtmlPattern" minlength="2" maxlength="50" placeholder="username">
                    <span class="lime-help">2-50 символов, латиница и цифры.</span>
                    <span asp-validation-for="Login" class="lime-validation"></span>
                </div>

                <div class="lime-field">
                    <label asp-for="Password" class="lime-label">Пароль</label>
                    <input asp-for="Password" class="lime-input" type="password" required minlength="8" placeholder="••••••••" oninput="window.LimeSignup&&window.LimeSignup.check()">
                    <span asp-validation-for="Password" class="lime-validation"></span>
                </div>

                <div class="lime-field">
                    <label class="lime-label" for="signup-confirm">Повторите пароль</label>
                    <input id="signup-confirm" class="lime-input" type="password" required minlength="8" placeholder="••••••••" oninput="window.LimeSignup&&window.LimeSignup.check()">
                    <span id="signup-confirm-msg" class="lime-help"></span>
                </div>

                <button type="submit" class="lime-btn lime-btn--primary lime-btn--lg" style="width:100%;margin-top:6px;">Зарегистрироваться →</button>
            </form>

            <div class="lime-auth__divider">
                Уже есть аккаунт? <a href="@Url.Action("SignIn")">Войти</a>
            </div>
        </div>

        <!-- aside -->
        <div class="lime-auth__aside">
            <div class="lime-auth__aside-glow"></div>
            <div class="lime-auth__aside-inner">
                <div class="lime-brand"><span class="lime-brand__mark" aria-hidden="true">L</span><span>Lime</span><span class="lime-brand__dot">.</span></div>
                <div class="lime-auth__quote display">Сделай первый сайт <em>сегодня</em> — без кода и без дизайнера.</div>
            </div>
            <div class="lime-auth__stat">
                <div><b class="display">12k+</b><span>сайтов собрано</span></div>
                <div><b class="display">30с</b><span>до первого экрана</span></div>
                <div><b class="display">0₽</b><span>чтобы начать</span></div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        window.LimeSignup = {
            check: function () {
                var passEl = document.querySelector('input[name="Password"]');
                var confirmEl = document.getElementById("signup-confirm");
                var msg = document.getElementById("signup-confirm-msg");
                if (!passEl || !confirmEl || !msg) { return; }
                var pass = passEl.value;
                var confirm = confirmEl.value;
                if (!confirm) { msg.textContent = ""; msg.className = "lime-help"; return; }
                if (pass === confirm) {
                    msg.textContent = "✓ Пароли совпадают";
                    msg.className = "lime-help";
                    msg.style.color = "var(--success)";
                } else {
                    msg.textContent = "Пароли не совпадают";
                    msg.className = "lime-validation";
                    msg.style.color = "";
                }
            }
        };
    </script>
}
