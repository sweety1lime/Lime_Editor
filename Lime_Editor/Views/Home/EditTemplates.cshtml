@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@model ConstructorViewModel
@{
    Layout = null;
    var theme = Context.Request.Cookies["lime_theme"];
    if (theme != "light" && theme != "dark") theme = "dark";
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var isEdit = Model.SiteId.HasValue;
}<!DOCTYPE html>
<html lang="ru" data-theme="@theme">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="X-CSRF-TOKEN" content="@csrfToken">
    <title>Конструктор · Lime</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/lime/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/base.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/components.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/constructor.css" asp-append-version="true">
    <script src="~/js/lime/theme.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
    <script src="~/js/lime/lime-animate.js" asp-append-version="true" defer></script>
</head>
<body>
    <div class="lime-editor">
        <div class="lime-editor__topbar">
            <div class="lime-editor__topbar-left">
                <a class="lime-btn lime-btn--ghost lime-btn--sm" href="/Home/MySites">← Назад</a>
                <span class="lime-text-muted" style="font-size: var(--text-sm);">@Model.SiteName</span>
                @if (isEdit)
                {
                    <span class="lime-badge lime-badge--muted">Редактирование</span>
                }
                else
                {
                    <span class="lime-badge lime-badge--accent">Новый сайт</span>
                }
            </div>
            <div class="lime-editor__topbar-center">
                <button type="button" class="lime-block-toolbar__btn" data-history-action="undo" title="Отменить (Ctrl+Z)">↶</button>
                <button type="button" class="lime-block-toolbar__btn" data-history-action="redo" title="Повторить (Ctrl+Y)">↷</button>
                <div class="lime-device-toggle" style="margin-left: var(--space-3);">
                    <button type="button" class="lime-device-toggle__btn is-active" data-device="desktop" title="Десктоп">🖥</button>
                    <button type="button" class="lime-device-toggle__btn" data-device="tablet" title="Планшет">📊</button>
                    <button type="button" class="lime-device-toggle__btn" data-device="mobile" title="Мобайл">📱</button>
                </div>
                <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-anim-preview title="Проиграть анимации" style="margin-left: var(--space-2);">▶ Превью</button>
            </div>
            <div class="lime-editor__topbar-right">
                <span class="lime-text-muted lime-save-status" data-save-status style="font-size: var(--text-xs); margin-right: var(--space-2);"></span>
                <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-seo-open title="SEO и мета">SEO</button>
                <button type="button" class="lime-theme-toggle" data-lime-theme-toggle title="Сменить тему">
                    <svg class="lime-theme-toggle__icon lime-theme-toggle__sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                    <svg class="lime-theme-toggle__icon lime-theme-toggle__moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                </button>
                <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-download-action>Скачать ZIP</button>
                <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-save-action data-site-id="@(Model.SiteId?.ToString() ?? "")">
                    @(isEdit ? "Обновить" : "Сохранить")
                </button>
            </div>
        </div>

        <aside class="lime-editor__sidebar">
            <input id="lime-block-search" class="lime-input lime-sidebar-search" type="search" placeholder="Поиск блоков...">

            <div class="lime-editor__sidebar-section">
                <h3>Базовые</h3>
                <button type="button" class="lime-block-tile" data-add-block="cover"><span class="lime-block-tile__icon">▢</span><span>Обложка</span></button>
                <button type="button" class="lime-block-tile" data-add-block="heading"><span class="lime-block-tile__icon">T</span><span>Заголовок</span></button>
                <button type="button" class="lime-block-tile" data-add-block="text"><span class="lime-block-tile__icon">¶</span><span>Текст</span></button>
                <button type="button" class="lime-block-tile" data-add-block="cta"><span class="lime-block-tile__icon">◉</span><span>CTA блок</span></button>
                <button type="button" class="lime-block-tile" data-add-block="features"><span class="lime-block-tile__icon">✦</span><span>Фичи (3 шт)</span></button>
                <button type="button" class="lime-block-tile" data-add-block="spacer"><span class="lime-block-tile__icon">↕</span><span>Отступ</span></button>
                <button type="button" class="lime-block-tile" data-add-block="buttonGroup"><span class="lime-block-tile__icon">⬚</span><span>Кнопки</span></button>
                <button type="button" class="lime-block-tile" data-add-block="divider"><span class="lime-block-tile__icon">—</span><span>Разделитель</span></button>
            </div>

            <div class="lime-editor__sidebar-section">
                <h3>Макет</h3>
                <button type="button" class="lime-block-tile" data-add-block="navbar"><span class="lime-block-tile__icon">≡</span><span>Навбар</span></button>
                <button type="button" class="lime-block-tile" data-add-block="heroBg"><span class="lime-block-tile__icon">▣</span><span>Hero с фоном</span></button>
                <button type="button" class="lime-block-tile" data-add-block="twoCol"><span class="lime-block-tile__icon">▥</span><span>2 колонки</span></button>
                <button type="button" class="lime-block-tile" data-add-block="footer"><span class="lime-block-tile__icon">▭</span><span>Футер</span></button>
                <button type="button" class="lime-block-tile" data-add-block="imageText"><span class="lime-block-tile__icon">◧</span><span>Картинка + текст</span></button>
                <button type="button" class="lime-block-tile" data-add-block="socials"><span class="lime-block-tile__icon">♥</span><span>Соцсети</span></button>
            </div>

            <div class="lime-editor__sidebar-section">
                <h3>Расширенные</h3>
                <button type="button" class="lime-block-tile" data-add-block="gallery"><span class="lime-block-tile__icon">▦</span><span>Галерея</span></button>
                <button type="button" class="lime-block-tile" data-add-block="pricing"><span class="lime-block-tile__icon">$</span><span>Цены</span></button>
                <button type="button" class="lime-block-tile" data-add-block="testimonials"><span class="lime-block-tile__icon">❝</span><span>Отзывы</span></button>
                <button type="button" class="lime-block-tile" data-add-block="accordion"><span class="lime-block-tile__icon">▼</span><span>FAQ / Аккордеон</span></button>
                <button type="button" class="lime-block-tile" data-add-block="contact"><span class="lime-block-tile__icon">✉</span><span>Форма контактов</span></button>
                <button type="button" class="lime-block-tile" data-add-block="video"><span class="lime-block-tile__icon">▶</span><span>YouTube видео</span></button>
                <button type="button" class="lime-block-tile" data-add-block="stats"><span class="lime-block-tile__icon">#</span><span>Статистика</span></button>
                <button type="button" class="lime-block-tile" data-add-block="logos"><span class="lime-block-tile__icon">❖</span><span>Логотипы</span></button>
                <button type="button" class="lime-block-tile" data-add-block="steps"><span class="lime-block-tile__icon">№</span><span>Шаги</span></button>
                <button type="button" class="lime-block-tile" data-add-block="table"><span class="lime-block-tile__icon">▤</span><span>Таблица</span></button>
                <button type="button" class="lime-block-tile" data-add-block="embed"><span class="lime-block-tile__icon">&lt;/&gt;</span><span>Свой код / Embed</span></button>
            </div>

            <div class="lime-editor__sidebar-section">
                <h3>Готовые секции</h3>
                <button type="button" class="lime-block-tile" data-add-section="starter"><span class="lime-block-tile__icon">★</span><span>Старт лендинга</span></button>
                <button type="button" class="lime-block-tile" data-add-section="product"><span class="lime-block-tile__icon">▣</span><span>Продукт</span></button>
                <button type="button" class="lime-block-tile" data-add-section="contact"><span class="lime-block-tile__icon">✉</span><span>Контакт-секция</span></button>
            </div>

            <div class="lime-editor__sidebar-section">
                <h3>Подсказки</h3>
                <p class="lime-text-muted" style="font-size: var(--text-xs); line-height: 1.5;">
                    Кликни на блок чтобы выбрать. Тяни за фиолетовую риску слева для перестановки.
                    На галерее кликни «+ выбрать» — откроется библиотека медиа.
                </p>
            </div>
        </aside>

        <main class="lime-editor__canvas">
            <div id="lime-workspace" class="lime-workspace" data-device="desktop">
                @if (!string.IsNullOrEmpty(Model.BodyHtml))
                {
                    @Html.Raw(Model.BodyHtml)
                }
            </div>
        </main>

        <aside class="lime-editor__inspector">
            <div class="lime-inspector__empty">
                Выбери блок в workspace, чтобы редактировать его стили.
            </div>
        </aside>
    </div>

    <!-- Media picker modal -->
    <div id="lime-media-modal" class="lime-modal-backdrop">
        <div class="lime-modal">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Выбери изображение</h3>
                <div class="lime-flex lime-gap-2 lime-items-center">
                    <label for="lime-media-upload" class="lime-btn lime-btn--soft lime-btn--sm" style="cursor:pointer;">+ Загрузить</label>
                    <input id="lime-media-upload" type="file" accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none;">
                    <button type="button" class="lime-modal__close" data-lime-modal-close aria-label="Закрыть">×</button>
                </div>
            </div>
            <div class="lime-modal__body">
                <div id="lime-media-status" class="lime-text-muted" style="display:none; margin-bottom: var(--space-3);"></div>
                <div id="lime-media-grid" class="lime-picker-grid">
                    <div class="lime-text-muted">Загрузка...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- SEO modal -->
    <div id="lime-seo-modal" class="lime-modal-backdrop">
        <div class="lime-modal">
            <div class="lime-modal__head">
                <h3 style="margin:0;">SEO и мета</h3>
                <button type="button" class="lime-modal__close" data-seo-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <label style="display:block; font-size: var(--text-xs); color: var(--fg-muted); margin: 0 0 4px;">Заголовок страницы (title)</label>
                <input id="lime-seo-title" class="lime-input" maxlength="200" value="@(Model.MetaTitle ?? "")" placeholder="@Model.SiteName" style="width:100%;">
                <label style="display:block; font-size: var(--text-xs); color: var(--fg-muted); margin: var(--space-3) 0 4px;">Описание (description)</label>
                <textarea id="lime-seo-desc" class="lime-input" rows="3" maxlength="400" placeholder="Краткое описание для поиска и соцсетей" style="width:100%; resize:vertical;">@(Model.MetaDescription ?? "")</textarea>
                <label style="display:block; font-size: var(--text-xs); color: var(--fg-muted); margin: var(--space-3) 0 4px;">OG-картинка (URL для превью в соцсетях)</label>
                <input id="lime-seo-og" class="lime-input" maxlength="400" value="@(Model.OgImage ?? "")" placeholder="/media/... или https://..." style="width:100%;">
                <p class="lime-text-muted" style="font-size: 11px; margin-top: var(--space-2);">Мета попадает в head опубликованной страницы. Изменения сохраняются автосейвом и при «Сохранить».</p>
                <div class="lime-flex lime-gap-2" style="justify-content:flex-end; margin-top: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-seo-close>Готово</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Embed (свой код) modal -->
    <div id="lime-embed-modal" class="lime-modal-backdrop">
        <div class="lime-modal">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Свой код / Embed</h3>
                <button type="button" class="lime-modal__close" data-lime-embed-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-2);">
                    Вставь HTML или код встраивания (Я.Карты, YouTube, виджет, форма сервиса). Рендерится в изолированном sandbox-iframe — без доступа к остальной странице.
                </p>
                <textarea id="lime-embed-input" class="lime-css-input" rows="9" spellcheck="false" placeholder="&lt;iframe src=&quot;https://...&quot;&gt;&lt;/iframe&gt;"></textarea>
                <div class="lime-flex lime-gap-2" style="justify-content: flex-end; margin-top: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-lime-embed-close>Отмена</button>
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-lime-embed-insert>Вставить</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/lime/constructor.js" asp-append-version="true" defer></script>
</body>
</html>
