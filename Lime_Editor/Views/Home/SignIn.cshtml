@model Lime_Editor.Models.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<section class="lime-auth">
    <div class="lime-auth__split reveal">
        <!-- form -->
        <div class="lime-auth__form-side">
            <h1 class="lime-auth__title display">С возвращением</h1>
            <p class="lime-auth__subtitle">Войди, чтобы продолжить работу над своими сайтами.</p>

            @if (TempData["Message"] != null)
            {
                <div class="lime-alert lime-alert--success lime-mb-4">@TempData["Message"]</div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                var summary = ViewData.ModelState[string.Empty];
                if (summary != null && summary.Errors.Count > 0)
                {
                    <div class="lime-alert lime-alert--danger lime-mb-4">
                        @summary.Errors.First().ErrorMessage
                    </div>
                }
            }

            <form asp-action="SignIn" asp-controller="Home" method="post" autocomplete="off">
                <div class="lime-field">
                    <label asp-for="Login" class="lime-label">Логин</label>
                    <input asp-for="Login" class="lime-input" type="text" autofocus required pattern="[A-z0-9.]{2,50}" placeholder="your_username">
                    <span asp-validation-for="Login" class="lime-validation"></span>
                </div>

                <div class="lime-field">
                    <label asp-for="Password" class="lime-label">Пароль</label>
                    <input asp-for="Password" class="lime-input" type="password" required placeholder="••••••••">
                    <span asp-validation-for="Password" class="lime-validation"></span>
                    <div style="text-align:right;margin-top:6px;">
                        <a href="@Url.Action("ForgotPassword")" class="lime-text-muted">Забыли пароль?</a>
                    </div>
                </div>

                <button type="submit" class="lime-btn lime-btn--primary lime-btn--lg" style="width:100%;margin-top:6px;">Войти →</button>
            </form>

            <div class="lime-auth__divider">
                Нет аккаунта? <a href="@Url.Action("SignUp")">Создать</a>
            </div>
        </div>

        <!-- aside -->
        <div class="lime-auth__aside">
            <div class="lime-auth__aside-glow"></div>
            <div class="lime-auth__aside-inner">
                <div class="lime-brand"><span class="lime-brand__mark" aria-hidden="true">L</span><span>Lime</span><span class="lime-brand__dot">.</span></div>
                <div class="lime-auth__quote display">Опиши идею — и смотри, как сайт <em>собирается сам</em>.</div>
            </div>
            <div class="lime-auth__stat">
                <div><b class="display">12k+</b><span>сайтов собрано</span></div>
                <div><b class="display">30с</b><span>до первого экрана</span></div>
                <div><b class="display">0₽</b><span>чтобы начать</span></div>
            </div>
        </div>
    </div>
</section>
