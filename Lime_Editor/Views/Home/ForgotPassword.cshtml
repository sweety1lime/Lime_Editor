@{
    ViewData["Title"] = "Восстановление пароля";
    var sent = ViewBag.Sent == true;
}

<section class="lime-auth">
    <div class="lime-auth__split reveal">
        <div class="lime-auth__form-side">
            <h1 class="lime-auth__title display">Забыли пароль?</h1>
            <p class="lime-auth__subtitle">Укажи email — пришлём ссылку для сброса пароля.</p>

            @if (sent)
            {
                <div class="lime-alert lime-alert--success lime-mb-4">
                    Если аккаунт с таким email существует, мы отправили ссылку для сброса пароля.
                    Проверь почту.
                </div>
                <div class="lime-auth__divider">
                    <a href="@Url.Action("SignIn")">← Вернуться ко входу</a>
                </div>
            }
            else
            {
                <form asp-action="ForgotPassword" asp-controller="Home" method="post" autocomplete="off">
                    <div class="lime-field">
                        <label class="lime-label" for="fp-email">Email</label>
                        <input class="lime-input" type="email" id="fp-email" name="email" autofocus required placeholder="you@example.com">
                    </div>
                    <button type="submit" class="lime-btn lime-btn--primary lime-btn--lg" style="width:100%;margin-top:6px;">Прислать ссылку</button>
                </form>

                <div class="lime-auth__divider">
                    Вспомнили? <a href="@Url.Action("SignIn")">Войти</a>
                </div>
            }
        </div>

        <div class="lime-auth__aside">
            <div class="lime-auth__aside-glow"></div>
            <div class="lime-auth__aside-inner">
                <div class="lime-brand"><span class="lime-brand__mark" aria-hidden="true">L</span><span>Lime</span><span class="lime-brand__dot">.</span></div>
                <div class="lime-auth__quote display">Доступ к твоим сайтам — в паре кликов.</div>
            </div>
        </div>
    </div>
</section>
