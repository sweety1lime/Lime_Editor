@model SiteControlModel
@{
    ViewData["Title"] = "Мои сайты";
    var sites = Model?.Sites ?? new List<Site>();
    var total = sites.Count;
    var published = sites.Count(s => s.IsPublished);
    var drafts = total - published;
    var leadCounts = ViewBag.LeadCounts as Dictionary<int, int>;
    var totalLeads = leadCounts?.Values.Sum() ?? 0;
}

<section class="lime-container" style="padding-top:54px;">
    <!-- HEAD -->
    <div class="lime-dash-head reveal">
        <div>
            <div class="lime-dash-hi">Привет, <span>@User.Identity.Name</span> 👋</div>
            <div class="lime-dash-sub">Управляй сайтами, публикуй, скачивай ZIP. Сегодня хороший день, чтобы что-то запустить.</div>
        </div>
        <div class="lime-dash-actions">
            <a class="lime-btn lime-btn--ghost" href="/Home/Templates">Шаблоны</a>
            <a class="lime-btn lime-btn--primary" href="/Home/EditDoc">
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z" fill="currentColor"/></svg>
                Новый сайт с AI
            </a>
        </div>
    </div>

    @if (TempData["PublishedMessage"] is string pubMessage)
    {
        var pubUrl = TempData["PublishedUrl"] as string;
        <div class="lime-alert lime-alert--success lime-mb-4">
            @pubMessage
            @if (!string.IsNullOrEmpty(pubUrl))
            {
                <span class="lime-alert__links">
                    <a href="@pubUrl" target="_blank" rel="noopener">Открыть сайт</a>
                </span>
            }
        </div>
    }
    @if (TempData["GitHubDeployError"] is string ghError)
    {
        <div class="lime-alert lime-alert--danger lime-mb-4">@ghError</div>
    }
    @if (TempData["GitHubDeployMessage"] is string ghMessage)
    {
        var ghUrl = TempData["GitHubDeployUrl"] as string;
        var ghVercelUrl = TempData["GitHubDeployVercelUrl"] as string;
        <div class="lime-alert lime-alert--success lime-mb-4">
            @ghMessage
            <span class="lime-alert__links">
                @if (!string.IsNullOrEmpty(ghUrl))
                {
                    <a href="@ghUrl" target="_blank" rel="noopener">Открыть GitHub</a>
                }
                @if (!string.IsNullOrEmpty(ghVercelUrl))
                {
                    <a href="@ghVercelUrl" target="_blank" rel="noopener">Импорт в Vercel</a>
                }
            </span>
        </div>
    }

    <!-- STATS -->
    <div class="lime-stats">
        <div class="lime-stat reveal" data-delay="1">
            <div class="lime-stat__label">Всего сайтов</div>
            <div class="lime-stat__value display"><span data-count="@total">0</span></div>
            <div class="lime-stat__spark"><svg width="56" height="24" viewBox="0 0 56 24" fill="none"><path d="M1 20L10 14L19 17L28 8L37 11L46 4L55 7" stroke="var(--lime)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        </div>
        <div class="lime-stat reveal" data-delay="2">
            <div class="lime-stat__label">Опубликовано</div>
            <div class="lime-stat__value display" style="color:var(--success);"><span data-count="@published">0</span></div>
        </div>
        <div class="lime-stat reveal" data-delay="3">
            <div class="lime-stat__label">Черновики</div>
            <div class="lime-stat__value display" style="color:var(--muted);"><span data-count="@drafts">0</span></div>
        </div>
        <div class="lime-stat reveal" data-delay="4">
            <div class="lime-stat__label">Заявки</div>
            <div class="lime-stat__value display" style="color:var(--violet);"><span data-count="@totalLeads">0</span></div>
        </div>
    </div>

    <!-- SITES -->
    <div class="lime-sites" style="padding-bottom:80px;">
        @foreach (var site in sites)
        {
            @* Скриншот-превью публикации (OgImage) в приоритете; для шаблонных сайтов — обложка шаблона. *@
            var previewSrc = !string.IsNullOrEmpty(site.OgImage) ? site.OgImage : site.TemplateInfo?.FolderPreview;
            var jsonEdit = Newtonsoft.Json.JsonConvert.SerializeObject(site);
            var unreadLeads = (leadCounts != null && site.IdSite.HasValue && leadCounts.ContainsKey(site.IdSite.Value))
                ? leadCounts[site.IdSite.Value] : 0;
            <div class="lime-site reveal">
                <div class="lime-site__preview">
                    @if (!string.IsNullOrEmpty(previewSrc))
                    {
                        <img src="@previewSrc" alt="@site.Name" loading="lazy">
                    }
                    else
                    {
                        <div class="lime-shot lime-shot-@(((site.IdSite ?? 0) % 6) + 1)"><div class="lime-shot__ui"><div class="lime-shot__bar" style="width:52%"></div><div class="lime-shot__bar dim" style="width:74%"></div><div class="lime-shot__chip"></div><div class="lime-shot__row"><div class="lime-shot__sq"></div><div class="lime-shot__sq"></div><div class="lime-shot__sq"></div></div></div></div>
                    }
                    <div class="lime-site__badges">
                        @if (site.IsPublished && !string.IsNullOrEmpty(site.Slug))
                        {
                            <span class="lime-badge lime-badge--success">Опубликован</span>
                            @if (site.HasUnpublishedChanges)
                            {
                                <span class="lime-badge lime-badge--warn">Есть изменения</span>
                            }
                        }
                        else if (site.IsPublished)
                        {
                            <span class="lime-badge lime-badge--warn">Нужна повторная публикация</span>
                        }
                        @* Черновик-бейдж не дублируем: строка «не опубликован» под именем уже говорит это. *@
                    </div>
                </div>
                <div class="lime-site__body">
                    <form asp-action="ChangeName" asp-controller="Home" method="post" class="lime-site__name-form">
                        <input type="hidden" name="idSite" value="@site.IdSite">
                        <input class="lime-site__name-input" name="site" value="@site.Name" required maxlength="100" aria-label="Название сайта">
                        <button type="submit" class="lime-btn lime-btn--ghost lime-btn--sm" title="Сохранить имя" aria-label="Сохранить имя">✓</button>
                    </form>

                    @if (site.IsPublished && !string.IsNullOrEmpty(site.Slug))
                    {
                        <a class="lime-site__url" href="/u/@User.Identity.Name/@site.Slug" target="_blank" rel="noopener">/u/@User.Identity.Name/@site.Slug</a>
                    }
                    else
                    {
                        <div class="lime-site__url lime-site__url--off">не опубликован</div>
                    }

                    <div class="lime-site__actions">
                        <form asp-action="UpdateSite" asp-controller="Home" method="post" style="display:inline;" data-lime-loading data-lime-loading-text="Открываем...">
                            <input type="hidden" name="site" value="@jsonEdit">
                            <button type="submit" class="lime-btn lime-btn--soft lime-btn--sm">Редактировать</button>
                        </form>
                        @if (site.IsPublished && !string.IsNullOrEmpty(site.Slug))
                        {
                            <a class="lime-btn lime-btn--ghost lime-btn--sm" href="/u/@User.Identity.Name/@site.Slug" target="_blank" rel="noopener">Открыть</a>
                        }
                        else
                        {
                            <form asp-action="Publish" asp-controller="Home" method="post" style="display:inline;" data-lime-loading data-lime-loading-text="Публикуем...">
                                <input type="hidden" name="idSite" value="@site.IdSite">
                                <button type="submit" class="lime-btn lime-btn--ghost lime-btn--sm">Опубликовать</button>
                            </form>
                        }
                        <a class="lime-btn lime-btn--ghost lime-btn--sm" href="/GitHub/Deploy?siteId=@site.IdSite" title="Выбрать способ деплоя в GitHub и Vercel">Деплой</a>
                        @if (unreadLeads > 0)
                        {
                            <a class="lime-btn lime-btn--ghost lime-btn--sm" href="/Form/Inbox?siteId=@site.IdSite">Заявки (@unreadLeads)</a>
                        }

                        <details class="lime-action-menu">
                            <summary class="lime-btn lime-btn--ghost lime-btn--sm" aria-label="Ещё действия">Ещё</summary>
                            <div class="lime-action-menu__panel">
                                @if (!string.IsNullOrEmpty(site.DocumentJson))
                                {
                                    <a class="lime-action-menu__item" href="/Home/EditDoc?siteId=@site.IdSite">Движок B</a>
                                }
                                @if (unreadLeads == 0)
                                {
                                    <a class="lime-action-menu__item" href="/Form/Inbox?siteId=@site.IdSite">Заявки</a>
                                }
                                <a class="lime-action-menu__item" href="/Data?siteId=@site.IdSite">Данные</a>
                                <a class="lime-action-menu__item" href="/Export/Nextjs?siteId=@site.IdSite">Код Next.js</a>
                                <a class="lime-action-menu__item" href="/Export/Nextjs?siteId=@site.IdSite&style=jsx">Код React</a>
                                @if (site.IsPublished)
                                {
                                    <form asp-action="ToggleGallery" asp-controller="Community" method="post" data-lime-loading data-lime-loading-text="Обновляем...">
                                        <input type="hidden" name="idSite" value="@site.IdSite">
                                        <button type="submit" class="lime-action-menu__item">
                                            @(site.ShowInGallery ? "Скрыть из галереи" : "Показать в галерее")
                                        </button>
                                    </form>
                                    <form asp-action="Unpublish" asp-controller="Home" method="post" data-lime-loading data-lime-loading-text="Снимаем...">
                                        <input type="hidden" name="idSite" value="@site.IdSite">
                                        <button type="submit" class="lime-action-menu__item">Снять с публикации</button>
                                    </form>
                                }
                                <form asp-action="DeleteSite" asp-controller="Home" method="post"
                                      data-lime-confirm
                                      data-lime-confirm-title="Удалить сайт?"
                                      data-lime-confirm-message="Сайт «@site.Name» будет удалён навсегда. Это действие нельзя отменить."
                                      data-lime-confirm-action="Удалить"
                                      data-lime-loading
                                      data-lime-loading-text="Удаляем...">
                                    <input type="hidden" name="site" value="@jsonEdit">
                                    <button type="submit" class="lime-action-menu__item lime-action-menu__item--danger">Удалить</button>
                                </form>
                            </div>
                        </details>
                    </div>
                </div>
            </div>
        }

        <!-- new site card -->
        <a class="lime-site lime-site--new reveal" href="/Home/EditDoc">
            <div>
                <div class="lime-site--new__ico"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg></div>
                <h3>Новый сайт</h3>
                <p>Опиши идею — AI соберёт за минуту</p>
            </div>
        </a>
    </div>
</section>
