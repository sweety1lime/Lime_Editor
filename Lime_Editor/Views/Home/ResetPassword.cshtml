@{
    ViewData["Title"] = "Новый пароль";
    var email = ViewBag.Email as string;
    var token = ViewBag.Token as string;
}

<section class="lime-auth">
    <div class="lime-auth__split reveal">
        <div class="lime-auth__form-side">
            <h1 class="lime-auth__title display">Новый пароль</h1>
            <p class="lime-auth__subtitle">Придумай новый пароль для входа в Lime.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                var summary = ViewData.ModelState[string.Empty];
                if (summary != null && summary.Errors.Count > 0)
                {
                    <div class="lime-alert lime-alert--danger lime-mb-4">
                        @foreach (var e in summary.Errors) { <div>@e.ErrorMessage</div> }
                    </div>
                }
            }

            <form asp-action="ResetPassword" asp-controller="Home" method="post" autocomplete="off">
                <input type="hidden" name="email" value="@email" />
                <input type="hidden" name="token" value="@token" />
                <div class="lime-field">
                    <label class="lime-label" for="rp-pass">Новый пароль</label>
                    <input class="lime-input" type="password" id="rp-pass" name="password" autocomplete="new-password" required minlength="8" placeholder="••••••••">
                    <span class="lime-text-muted">Минимум 8 символов и хотя бы одна цифра.</span>
                </div>
                <button type="submit" class="lime-btn lime-btn--primary lime-btn--lg" style="width:100%;margin-top:6px;">Сохранить пароль</button>
            </form>

            <div class="lime-auth__divider">
                <a href="@Url.Action("SignIn")">← Вернуться ко входу</a>
            </div>
        </div>

        <div class="lime-auth__aside">
            <div class="lime-auth__aside-glow"></div>
            <div class="lime-auth__aside-inner">
                <div class="lime-brand"><span class="lime-brand__mark" aria-hidden="true">L</span><span>Lime</span><span class="lime-brand__dot">.</span></div>
                <div class="lime-auth__quote display">Безопасность аккаунта — в твоих руках.</div>
            </div>
        </div>
    </div>
</section>
