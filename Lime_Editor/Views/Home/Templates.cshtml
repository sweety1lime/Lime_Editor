@model List<Lime_Editor.Models.Template>
@{
    ViewData["Title"] = "Шаблоны";
    // Custom (Id=4) — внутренний "пустой" шаблон, в галерее его не показываем.
    var publicTemplates = (Model ?? new List<Lime_Editor.Models.Template>())
        .Where(t => t.IdTemplate != 4)
        .ToList();
}

<section class="lime-container lime-band">
    <div class="reveal">
        <div class="lime-eyebrow">Галерея</div>
        <h1 class="display">Старт за секунду</h1>
        <p>Выбери точку отсчёта — каждый шаблон полностью редактируется в конструкторе. Или начни с чистого листа и дай AI собрать первый вариант.</p>
    </div>
</section>

<section class="lime-container" style="padding:34px 0 60px;">
    @if (publicTemplates.Count == 0)
    {
        <div class="lime-empty lime-card">
            <div class="lime-empty__title">Шаблонов пока нет</div>
            <p>Зайди позже или собери сайт с нуля.</p>
            <a class="lime-btn lime-btn--primary lime-mt-4" href="/Home/EditDoc">Создать с нуля</a>
        </div>
    }
    else
    {
        <div class="lime-tpl-grid">
            @{ var li = 0; }
            @foreach (var t in publicTemplates)
            {
                <div class="lime-tpl reveal" data-delay="@((li++ % 3) + 1)">
                    <div class="lime-tpl__preview">
                        @if (!string.IsNullOrEmpty(t.FolderPreview))
                        {
                            <img src="@t.FolderPreview" alt="@t.Name" loading="lazy">
                        }
                        else
                        {
                            <div class="lime-shot lime-shot-@(((li) % 6) + 1)"><div class="lime-shot__ui"><div class="lime-shot__bar" style="width:54%"></div><div class="lime-shot__bar dim" style="width:76%"></div><div class="lime-shot__chip"></div><div class="lime-shot__row"><div class="lime-shot__sq"></div><div class="lime-shot__sq"></div><div class="lime-shot__sq"></div></div></div></div>
                        }
                        <span class="lime-tpl__tag lime-badge lime-badge--muted">Шаблон</span>
                    </div>
                    <div class="lime-tpl__body">
                        <div><div class="lime-tpl__name">@t.Name</div><div class="lime-tpl__type">Готовый шаблон</div></div>
                        <div class="lime-tpl__actions">
                            <a class="lime-btn lime-btn--soft lime-btn--sm" href="@Url.Action($"Template_{t.IdTemplate}", "Template")">Открыть →</a>
                            <a class="lime-btn lime-btn--ghost lime-btn--sm" href="@Url.Action($"Template_{t.IdTemplate}_Preview", "Template")" target="_blank" rel="noopener">Превью</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<section class="lime-container" style="padding-bottom:90px;">
    <div class="lime-finalcta reveal" style="padding:56px 48px;">
        <div class="lime-finalcta__glow"></div>
        <div class="lime-finalcta__inner" style="display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;text-align:left;">
            <div>
                <h2 style="font-size:clamp(28px,3.4vw,40px);margin-bottom:8px;">Не нашёл <em>подходящий</em>?</h2>
                <p style="margin:0;font-size:16px;">Опиши идею словами — AI соберёт сайт с нуля за минуту.</p>
            </div>
            <a class="lime-btn lime-btn--primary lime-btn--lg" href="/Home/EditDoc">
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z" fill="currentColor"/></svg>
                Создать с нуля
            </a>
        </div>
    </div>
</section>
