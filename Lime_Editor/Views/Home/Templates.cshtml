@{
    ViewData["Title"] = "Шаблоны";
}

<section class="lime-container lime-band">
    <div class="reveal">
        <div class="lime-eyebrow">Галерея</div>
        <h1 class="display">Старт за секунду</h1>
        <p>Выбери точку отсчёта — каждый шаблон полностью редактируется в конструкторе. Или начни с чистого листа и дай AI собрать первый вариант.</p>
    </div>
</section>

<section class="lime-container" style="padding:10px 0 20px;">
    <div class="reveal">
        <div class="lime-eyebrow">Дизайн-шаблоны</div>
        <h2 style="font-size:clamp(24px,3vw,34px);margin-bottom:8px;">Готовые сайты — бери и меняй контент</h2>
        <p style="margin:0;">Целый сайт с палитрой, секциями и анимацией. Открывается в конструкторе — правь текст и картинки.</p>
    </div>
    <div id="lime-tpl-filter" class="lime-tpl-filter" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:18px;"></div>
    <div id="lime-tpl-b-grid" class="lime-tpl-grid" style="margin-top:20px;"></div>
</section>
<script src="~/js/lime/lime-presets.js" asp-append-version="true"></script>
<script src="~/js/lime/lime-templates.js" asp-append-version="true"></script>
<script>
    (function () {
        var box = document.getElementById("lime-tpl-b-grid");
        var filterBox = document.getElementById("lime-tpl-filter");
        if (!box || !window.LimeTemplates) return;
        var list = window.LimeTemplates;

        // Фильтр по стилю.
        var styles = ["Все"];
        list.forEach(function (t) { if (t.style && styles.indexOf(t.style) < 0) styles.push(t.style); });
        if (filterBox) {
            filterBox.innerHTML = styles.map(function (s, i) {
                return '<button type="button" class="lime-btn lime-btn--sm ' + (i === 0 ? "lime-btn--primary" : "lime-btn--ghost") + '" data-style="' + s + '">' + s + '</button>';
            }).join("");
            filterBox.addEventListener("click", function (e) {
                var btn = e.target.closest("[data-style]");
                if (!btn) return;
                var s = btn.getAttribute("data-style");
                filterBox.querySelectorAll("[data-style]").forEach(function (b) {
                    b.className = "lime-btn lime-btn--sm " + (b === btn ? "lime-btn--primary" : "lime-btn--ghost");
                });
                box.querySelectorAll("[data-tpl-style]").forEach(function (card) {
                    card.style.display = (s === "Все" || card.getAttribute("data-tpl-style") === s) ? "" : "none";
                });
            });
        }

        box.innerHTML = list.map(function (t) {
            var chips = (t.sections || []).slice(0, 8).map(function (s) {
                return '<span class="lime-badge lime-badge--muted" style="font-size:10px;">' + s + '</span>';
            }).join(" ");
            var grad = "linear-gradient(135deg," + t.theme.accent + "," + t.theme.accent2 + ")";
            return '<div class="lime-tpl reveal" data-tpl-style="' + (t.style || "") + '">' +
                '<div class="lime-tpl__preview" style="background:' + t.theme.bg + ';display:flex;align-items:center;justify-content:center;">' +
                '<div style="width:72%;height:58%;border-radius:16px;background:' + grad + ';box-shadow:0 18px 50px rgba(0,0,0,.35);"></div>' +
                '<span class="lime-tpl__tag lime-badge lime-badge--muted">' + (t.style || "Движок B") + '</span></div>' +
                '<div class="lime-tpl__body">' +
                '<div><div class="lime-tpl__name">' + t.name + '</div><div class="lime-tpl__type">' + t.desc + '</div>' +
                '<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:8px;">' + chips + '</div></div>' +
                '<div class="lime-tpl__actions" style="margin-top:12px;">' +
                '<a class="lime-btn lime-btn--primary lime-btn--sm" href="/Home/EditDoc?template=' + t.key + '">Взять шаблон →</a></div>' +
                '</div></div>';
        }).join("");
    })();
</script>

<section class="lime-container" style="padding-bottom:90px;">
    <div class="lime-finalcta reveal" style="padding:56px 48px;">
        <div class="lime-finalcta__glow"></div>
        <div class="lime-finalcta__inner" style="display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;text-align:left;">
            <div>
                <h2 style="font-size:clamp(28px,3.4vw,40px);margin-bottom:8px;">Не нашёл <em>подходящий</em>?</h2>
                <p style="margin:0;font-size:16px;">Опиши идею словами — AI соберёт сайт с нуля за минуту.</p>
            </div>
            <a class="lime-btn lime-btn--primary lime-btn--lg" href="/Home/EditDoc">
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z" fill="currentColor"/></svg>
                Создать с нуля
            </a>
        </div>
    </div>
</section>
