@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@model ConstructorViewModel
@{
    Layout = null;
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var isEdit = Model.SiteId.HasValue;
    // Защита от закрытия </script> в пользовательском контенте при инлайне JSON.
    var seedJson = (Model.DocumentJson ?? "null").Replace("</", "<\\/");
    // Стартовый шаблон (Фаза 3.2) — только для нового документа; ключ санитайзим.
    var templateKey = isEdit ? "" : System.Text.RegularExpressions.Regex.Replace(
        Context.Request.Query["template"].ToString() ?? "", "[^a-zA-Z0-9_-]", "");
    // Раскатка Editor V2: дефолт нового редактора (Editor:V2Default, по умолчанию true).
    var v2DefaultCfg = Config["Editor:V2Default"];
    var v2Default = v2DefaultCfg == null || !v2DefaultCfg.Equals("false", StringComparison.OrdinalIgnoreCase);
}<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="X-CSRF-TOKEN" content="@csrfToken">
    <title>Конструктор · Lime</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&family=Unbounded:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800&family=Onest:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/lime/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/base.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/components.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/constructor.css" asp-append-version="true">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js" defer></script>
    <script>
        window.__LIME_DOC__ = @Html.Raw(seedJson);
        window.__LIME_DOC_VERSION__ = @Model.DocVersion; // Site.UpdatedAt.Ticks — optimistic concurrency
        window.__LIME_TEMPLATE__ = @Html.Raw(string.IsNullOrEmpty(templateKey) ? "null" : "\"" + templateKey + "\"");
        // Раскатка Editor V2: дефолт нового редактора задаётся сервером (Editor:V2Default).
        window.__LIME_V2_DEFAULT__ = @(v2Default ? "true" : "false");
    </script>
</head>
<body>
    @* Единый icon-set (редизайн редактора): инлайн-SVG спрайт, без внешних зависимостей.
       Иконки используются через <svg class="lime-ico"><use href="#i-..."/></svg>; цвет — currentColor. *@
    <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false" overflow="hidden">
        <defs>
            <symbol id="i-plus" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></symbol>
            <symbol id="i-layers" viewBox="0 0 24 24"><path d="M12 3 2 8l10 5 10-5-10-5Z"/><path d="M2 16l10 5 10-5"/><path d="M2 12l10 5 10-5"/></symbol>
            <symbol id="i-grid" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></symbol>
            <symbol id="i-monitor" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></symbol>
            <symbol id="i-tablet" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2.5"/><path d="M12 18h.01"/></symbol>
            <symbol id="i-phone" viewBox="0 0 24 24"><rect x="7" y="2" width="10" height="20" rx="2.5"/><path d="M11 18h2"/></symbol>
            <symbol id="i-undo" viewBox="0 0 24 24"><path d="M9 14 4 9l5-5"/><path d="M4 9h11a5 5 0 0 1 0 10h-4"/></symbol>
            <symbol id="i-redo" viewBox="0 0 24 24"><path d="m15 14 5-5-5-5"/><path d="M20 9H9a5 5 0 0 0 0 10h4"/></symbol>
            <symbol id="i-more" viewBox="0 0 24 24"><circle cx="5" cy="12" r="1.6" fill="currentColor" stroke="none"/><circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none"/><circle cx="19" cy="12" r="1.6" fill="currentColor" stroke="none"/></symbol>
            <symbol id="i-navbar" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/></symbol>
            <symbol id="i-footer" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 15h18"/></symbol>
            <symbol id="i-container" viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2"/></symbol>
            <symbol id="i-columns" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M12 4v16"/></symbol>
            <symbol id="i-cover" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9h10M7 13h6"/><rect x="7" y="16" width="7" height="2.5" rx="1.25"/></symbol>
            <symbol id="i-heading" viewBox="0 0 24 24"><path d="M6 4v16M18 4v16M6 12h12"/></symbol>
            <symbol id="i-text" viewBox="0 0 24 24"><path d="M5 7h14M5 11h14M5 15h10M5 19h12"/></symbol>
            <symbol id="i-features" viewBox="0 0 24 24"><path d="M12 3c.6 4.4 1 4.8 5.4 5.4-4.4.6-4.8 1-5.4 5.4-.6-4.4-1-4.8-5.4-5.4 4.4-.6 4.8-1 5.4-5.4Z"/><path d="M18.5 14.5c.3 2 .5 2.2 2.5 2.5-2 .3-2.2.5-2.5 2.5-.3-2-.5-2.2-2.5-2.5 2-.3 2.2-.5 2.5-2.5Z"/></symbol>
            <symbol id="i-stats" viewBox="0 0 24 24"><path d="M3 20h18"/><path d="M6 20v-6M12 20V8M18 20v-9"/></symbol>
            <symbol id="i-steps" viewBox="0 0 24 24"><path d="M3 7h11M14 7l-3-3M14 7l-3 3"/><path d="M21 17H10M10 17l3-3M10 17l3 3"/></symbol>
            <symbol id="i-testimonials" viewBox="0 0 24 24"><path d="M4 5h16v10H9l-4 4V5z"/><path d="M8 9h8M8 12h5"/></symbol>
            <symbol id="i-faq" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M9.5 9.5a2.5 2.5 0 1 1 3.2 2.4c-.9.3-1.2.9-1.2 1.6"/><path d="M11.5 16.5h.01"/></symbol>
            <symbol id="i-logos" viewBox="0 0 24 24"><circle cx="5.5" cy="12" r="2.5"/><circle cx="12" cy="12" r="2.5"/><circle cx="18.5" cy="12" r="2.5"/></symbol>
            <symbol id="i-imagetext" viewBox="0 0 24 24"><rect x="3" y="5" width="8" height="14" rx="1.5"/><circle cx="6" cy="9" r="1.1" fill="currentColor" stroke="none"/><path d="M3 16l3-2.5 2 1.3"/><path d="M14 8h7M14 12h7M14 16h5"/></symbol>
            <symbol id="i-collection" viewBox="0 0 24 24"><circle cx="5" cy="7" r="1.2" fill="currentColor" stroke="none"/><circle cx="5" cy="12" r="1.2" fill="currentColor" stroke="none"/><circle cx="5" cy="17" r="1.2" fill="currentColor" stroke="none"/><path d="M9 7h11M9 12h11M9 17h11"/></symbol>
            <symbol id="i-image" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.6"/><path d="M3 16l5-4 4 3 3-2 6 5"/></symbol>
            <symbol id="i-gallery" viewBox="0 0 24 24"><rect x="8" y="3" width="13" height="10" rx="1.5"/><rect x="3" y="9" width="13" height="12" rx="1.5"/><circle cx="7" cy="13" r="1.2"/><path d="M3.5 19l3-2.5 3 2"/></symbol>
            <symbol id="i-video" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M11 9.5l4 2.5-4 2.5z" fill="currentColor" stroke="none"/></symbol>
            <symbol id="i-embed" viewBox="0 0 24 24"><path d="M9 8l-4 4 4 4M15 8l4 4-4 4"/></symbol>
            <symbol id="i-tabs" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v5"/></symbol>
            <symbol id="i-carousel" viewBox="0 0 24 24"><rect x="7" y="6" width="10" height="12" rx="1.5"/><path d="M4 8v8M20 8v8"/></symbol>
            <symbol id="i-lightbox" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><circle cx="17.5" cy="17.5" r="2.6"/><path d="M19.6 19.6 21.5 21.5"/></symbol>
            <symbol id="i-countdown" viewBox="0 0 24 24"><circle cx="12" cy="13" r="8"/><path d="M12 13V9M12 13l3 2M9 2h6"/></symbol>
            <symbol id="i-modal" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 9h18"/><circle cx="7" cy="7" r="0.6" fill="currentColor" stroke="none"/></symbol>
            <symbol id="i-cta" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/></symbol>
            <symbol id="i-form" viewBox="0 0 24 24"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 8h8M8 12h8"/><rect x="8" y="15.5" width="6" height="2.5" rx="1.25"/></symbol>
            <symbol id="i-pricing" viewBox="0 0 24 24"><path d="M3 11.5V4a1 1 0 0 1 1-1h7.5a1 1 0 0 1 .7.3l8 8a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-8-8a1 1 0 0 1-.3-.7z"/><circle cx="7.5" cy="7.5" r="1.5"/></symbol>
            <symbol id="i-buttons" viewBox="0 0 24 24"><rect x="3" y="8.5" width="8" height="7" rx="3.5"/><rect x="13" y="8.5" width="8" height="7" rx="3.5"/></symbol>
            <symbol id="i-socials" viewBox="0 0 24 24"><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M8.2 10.8l7.6-3.6M8.2 13.2l7.6 3.6"/></symbol>
            <symbol id="i-divider" viewBox="0 0 24 24"><path d="M3 12h6M15 12h6"/><circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/></symbol>
            <symbol id="i-spacer" viewBox="0 0 24 24"><path d="M5 4h14M5 20h14"/><path d="M12 8v8M9 11l3-3 3 3M9 13l3 3 3-3"/></symbol>
            <symbol id="i-free" viewBox="0 0 24 24"><path d="M12 3v18M3 12h18"/><path d="M9.5 5.5 12 3l2.5 2.5M9.5 18.5 12 21l2.5-2.5M5.5 9.5 3 12l2.5 2.5M18.5 9.5 21 12l-2.5 2.5"/></symbol>
            <symbol id="i-up" viewBox="0 0 24 24"><path d="M12 19V5M6 11l6-6 6 6"/></symbol>
            <symbol id="i-down" viewBox="0 0 24 24"><path d="M12 5v14M6 13l6 6 6-6"/></symbol>
            <symbol id="i-out" viewBox="0 0 24 24"><path d="M14 5h4a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-4"/><path d="M10 12H3M6 8l-4 4 4 4"/></symbol>
            <symbol id="i-copy" viewBox="0 0 24 24"><rect x="8" y="8" width="13" height="13" rx="2"/><path d="M5 15a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2"/></symbol>
            <symbol id="i-duplicate" viewBox="0 0 24 24"><rect x="8" y="8" width="13" height="13" rx="2"/><path d="M5 15a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2"/><path d="M14.5 13v4M12.5 15h4"/></symbol>
            <symbol id="i-paste" viewBox="0 0 24 24"><rect x="9" y="2.5" width="6" height="4" rx="1"/><path d="M9 4.5H7a2 2 0 0 0-2 2V20a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V6.5a2 2 0 0 0-2-2h-2"/></symbol>
            <symbol id="i-trash" viewBox="0 0 24 24"><path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M6 7l1 13a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-13"/></symbol>
            <symbol id="i-ungroup" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" rx="1.5"/><rect x="13" y="13" width="8" height="8" rx="1.5"/></symbol>
            <symbol id="i-palette" viewBox="0 0 24 24"><path d="M12 3a9 9 0 1 0 0 18 2 2 0 0 0 2-2c0-.5-.2-1-.5-1.3-.3-.4-.5-.8-.5-1.2a2 2 0 0 1 2-2h1.5A4 4 0 0 0 21 8.5C21 5.4 16.9 3 12 3z"/><circle cx="7.5" cy="10.5" r="1.1" fill="currentColor" stroke="none"/><circle cx="12" cy="7.5" r="1.1" fill="currentColor" stroke="none"/><circle cx="16" cy="10.5" r="1.1" fill="currentColor" stroke="none"/></symbol>
            <symbol id="i-play" viewBox="0 0 24 24"><path d="M7 5l12 7-12 7z" fill="currentColor" stroke="none"/></symbol>
        </defs>
    </svg>
    <div class="lime-editor">
        <div class="lime-editor__topbar">
            <div class="lime-editor__topbar-left">
                <a class="lime-editor__mark" href="/Home/MySites" title="К моим сайтам" aria-label="К моим сайтам">L</a>
                <span class="lime-text-muted" style="font-size: var(--text-sm);">@Model.SiteName</span>
                <span class="lime-badge lime-badge--accent">@(isEdit ? "редактор" : "черновик")</span>
            </div>
            <div class="lime-editor__topbar-center">
                <div class="lime-flex lime-gap-2" style="margin-right: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm lime-btn--icon" data-doc-undo disabled title="Отменить (Ctrl+Z)" aria-label="Отменить"><svg class="lime-ico"><use href="#i-undo"/></svg></button>
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm lime-btn--icon" data-doc-redo disabled title="Вернуть (Ctrl+Shift+Z)" aria-label="Вернуть"><svg class="lime-ico"><use href="#i-redo"/></svg></button>
                </div>
                <div class="lime-device-toggle">
                    <button type="button" class="lime-device-toggle__btn is-active" data-doc-bp="base" title="Десктоп" aria-label="Десктоп"><svg class="lime-ico"><use href="#i-monitor"/></svg></button>
                    <button type="button" class="lime-device-toggle__btn" data-doc-bp="tablet" title="Планшет" aria-label="Планшет"><svg class="lime-ico"><use href="#i-tablet"/></svg></button>
                    <button type="button" class="lime-device-toggle__btn" data-doc-bp="mobile" title="Мобайл" aria-label="Мобайл"><svg class="lime-ico"><use href="#i-phone"/></svg></button>
                </div>
                <div class="lime-canvas-zoom" data-canvas-controls hidden>
                    <button type="button" data-canvas-zoom-out title="Уменьшить">−</button>
                    <button type="button" data-canvas-zoom-label title="100%">100%</button>
                    <button type="button" data-canvas-zoom-in title="Увеличить">+</button>
                    <button type="button" data-canvas-fit title="Вместить страницу">Fit</button>
                </div>
            </div>
            <div class="lime-editor__topbar-right">
                <span class="lime-text-muted" data-doc-status style="font-size: var(--text-xs); margin-right: var(--space-2);"></span>
                <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm lime-cmdk-btn" data-doc-cmdk title="Команды и поиск (Ctrl+K)" aria-keyshortcuts="Control+K"><span>Команды</span><kbd>⌘K</kbd></button>
                @if (Model.HasOriginalBackup)
                {
                    <form method="post" action="/Home/RestoreOriginal" style="display:inline;"
                          onsubmit="return confirm('Восстановить сайт к исходному виду до правок в новом редакторе? Текущий черновик будет заменён.');">
                        <input type="hidden" name="__RequestVerificationToken" value="@csrfToken" />
                        <input type="hidden" name="siteId" value="@Model.SiteId" />
                        <button type="submit" class="lime-btn lime-btn--ghost lime-btn--sm" title="Откатить к версии до перехода на новый редактор"><svg class="lime-ico"><use href="#i-undo"/></svg> Оригинал</button>
                    </form>
                }
                <div class="lime-topbar-more" data-topbar-more>
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm lime-btn--icon" data-topbar-more-toggle aria-haspopup="menu" aria-expanded="false" title="Ещё действия" aria-label="Ещё действия"><svg class="lime-ico"><use href="#i-more"/></svg></button>
                    <div class="lime-topbar-more__menu" role="menu" hidden>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-ai-open title="Сгенерировать страницу по описанию"><svg class="lime-ico"><use href="#i-features"/></svg> AI заново</button>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-theme-open title="Тема сайта"><svg class="lime-ico"><use href="#i-palette"/></svg> Тема сайта</button>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-code-open title="Глобальный CSS и код в head"><svg class="lime-ico"><use href="#i-embed"/></svg> Код сайта</button>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-anim-preview title="Проиграть анимации появления"><svg class="lime-ico"><use href="#i-play"/></svg> Превью анимаций</button>
                        @if (isEdit)
                        {
                            <div style="height:1px; background: var(--line); margin: 4px 0;"></div>
                            <a class="lime-topbar-more__item" role="menuitem" href="/Export/Nextjs?siteId=@Model.SiteId&style=blob" title="Скачать сайт как готовый проект Next.js (рендер движком)"><svg class="lime-ico"><use href="#i-down"/></svg> Скачать код (Next.js)</a>
                            <a class="lime-topbar-more__item" role="menuitem" href="/Export/Nextjs?siteId=@Model.SiteId&style=jsx" title="Скачать как Next.js с React-компонентами"><svg class="lime-ico"><use href="#i-down"/></svg> Скачать код (React)</a>
                        }
                    </div>
                </div>
                <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-save data-site-id="@(Model.SiteId?.ToString() ?? "")">
                    @(isEdit ? "Обновить" : "Опубликовать")
                </button>
            </div>
        </div>

        <aside class="lime-editor__sidebar" aria-label="Панели редактора">
            <nav class="lime-sidebar-rail" aria-label="Разделы редактора">
                <button type="button" class="lime-sidebar-rail__btn is-active" data-sidebar-panel-toggle="insert" aria-controls="lime-sidebar-panel-insert" aria-pressed="true" title="Вставка" aria-label="Вставка"><svg class="lime-ico"><use href="#i-plus"/></svg></button>
                <button type="button" class="lime-sidebar-rail__btn" data-sidebar-panel-toggle="layers" aria-controls="lime-sidebar-panel-layers" aria-pressed="false" title="Слои" aria-label="Слои"><svg class="lime-ico"><use href="#i-layers"/></svg></button>
                <button type="button" class="lime-sidebar-rail__btn" data-sidebar-panel-toggle="components" aria-controls="lime-sidebar-panel-components" aria-pressed="false" title="Компоненты" aria-label="Компоненты"><svg class="lime-ico"><use href="#i-grid"/></svg></button>
            </nav>
            <div class="lime-sidebar-panels">
            <div class="lime-sidebar-panel is-active" id="lime-sidebar-panel-insert" data-sidebar-panel="insert">
            <div class="lime-editor__sidebar-section">
                <h3>Блоки</h3>
                <input type="search" id="lime-block-search" class="lime-sidebar-search" placeholder="Поиск блока…" autocomplete="off">
                <details class="lime-tile-group" open>
                    <summary>Структура</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="navbar"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-navbar"/></svg></span><span>Навбар</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="footer"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-footer"/></svg></span><span>Подвал</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="container"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-container"/></svg></span><span>Контейнер</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="columns"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-columns"/></svg></span><span>Колонки</span></button>
                    </div>
                </details>
                <details class="lime-tile-group" open>
                    <summary>Контент</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="cover"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-cover"/></svg></span><span>Обложка</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="heading"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-heading"/></svg></span><span>Заголовок</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="text"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-text"/></svg></span><span>Текст</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="features"><span class="lime-block-tile__icon"><svg class="lime-ico"><use href="#i-features"/></svg></span><span>Фичи</span></button>
