    <!-- AI generation status pill + toast -->
    <div class="lime-le-status" id="lime-doc-le-status">
        <span class="lime-le-spinner" id="lime-doc-le-spinner"></span>
        <span class="lime-le-status__text" id="lime-doc-le-status-text">Разбираю запрос…</span>
    </div>
    <div class="lime-le-toast" id="lime-doc-le-toast"><b>✓ Сайт готов.</b> Можно править блоки.</div>

    <!-- Theme (тема сайта) modal -->
    <div id="lime-doc-theme-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 440px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Тема сайта</h3>
                <button type="button" class="lime-modal__close" data-doc-theme-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-3);">
                    Токены применяются ко всему сайту. Поменяешь раз — обновится везде, где блок ссылается на токен (свотчи под цветами в инспекторе).
                </p>
                <label class="lime-field-label">Готовые палитры</label>
                <div id="lime-theme-palettes" class="lime-theme-palettes"></div>
                <div style="height:1px; background: var(--line); margin: var(--space-3) 0;"></div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Акцент</span>
                    <input type="color" id="lime-theme-accent" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Акцент 2</span>
                    <input type="color" id="lime-theme-accent2" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Фон сайта</span>
                    <input type="color" id="lime-theme-bg" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Текст</span>
                    <input type="color" id="lime-theme-fg" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-3);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Приглушённый</span>
                    <input type="color" id="lime-theme-muted" class="lime-color-input">
                </div>
                <label class="lime-field-label">Шрифт</label>
                <select id="lime-theme-font" class="lime-select" style="width:100%;">
                    <option value="'Inter', system-ui, sans-serif">Inter</option>
                    <option value="'Space Grotesk', system-ui, sans-serif">Space Grotesk</option>
                    <option value="'Manrope', system-ui, sans-serif">Manrope</option>
                    <option value="'Unbounded', system-ui, sans-serif">Unbounded (дисплейный)</option>
                    <option value="'Montserrat', system-ui, sans-serif">Montserrat</option>
                    <option value="'Onest', system-ui, sans-serif">Onest</option>
                    <option value="'Instrument Serif', Georgia, serif">Instrument Serif</option>
                    <option value="system-ui, -apple-system, sans-serif">Системный</option>
                    <option value="Georgia, 'Times New Roman', serif">Georgia</option>
                </select>
                <div class="lime-flex lime-gap-2" style="justify-content:flex-end; margin-top: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-theme-close>Готово</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Менеджер страниц (этап 0.3) -->
    <div id="lime-doc-pages-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 560px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Страницы сайта</h3>
                <button type="button" class="lime-modal__close" data-doc-pages-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-3);">
                    Первая страница — главная (адрес сайта). У остальных адрес = слаг: <code>/u/user/slug/страница</code>.
                </p>
                <div id="lime-doc-pages-list"></div>
                <button type="button" class="lime-btn lime-btn--soft lime-btn--sm" data-doc-page-add-modal style="margin-top: var(--space-3);">＋ Добавить страницу</button>
            </div>
        </div>
    </div>

    <!-- Код сайта (этап 0.2): глобальный CSS + кастомный head -->
    <div id="lime-doc-code-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 640px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">&lt;/&gt; Код сайта</h3>
                <button type="button" class="lime-modal__close" data-doc-code-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <label class="lime-field-label">
                    Глобальный CSS <span class="lime-text-muted">— применяется ко всему сайту, идёт после стилей блоков (может их перебить)</span>
                </label>
                <textarea id="lime-doc-custom-css" class="lime-textarea" rows="8" spellcheck="false"
                          style="width:100%; font-family: var(--font-mono, monospace); font-size: var(--text-sm);"
                          placeholder=".lime-block__heading { letter-spacing: -.02em }&#10;a { transition: color .2s }"></textarea>
                <label class="lime-field-label" style="margin-top: var(--space-3);">
                    Код в &lt;head&gt; <span class="lime-text-muted">— мета-теги, верификации, шрифты, &lt;link&gt;/&lt;style&gt;</span>
                </label>
                <textarea id="lime-doc-custom-head" class="lime-textarea" rows="6" spellcheck="false"
                          style="width:100%; font-family: var(--font-mono, monospace); font-size: var(--text-sm);"
                          placeholder='&lt;meta name="yandex-verification" content="..."&gt;&#10;&lt;link rel="stylesheet" href="https://..."&gt;'></textarea>
                <div class="lime-editor__hint" style="margin-top: var(--space-2);">
                    В целях безопасности &lt;script&gt; в head пока вырезается на публикации (разблокируется после выноса публикаций на отдельный домен). Разрешены meta, link, style.
                </div>
                <div class="lime-flex lime-gap-2" style="justify-content:flex-end; margin-top: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-code-close>Готово</button>
                </div>
            </div>
        </div>
    </div>

    <!-- AI modal (описание бизнеса → блоки) -->
    <div id="lime-doc-ai-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 560px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">✨ Сгенерировать страницу</h3>
                <button type="button" class="lime-modal__close" data-doc-ai-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-3);">
                    Опиши бизнес или проект — AI соберёт лендинг из блоков конструктора прямо на активной странице.
                    Потом всё можно править как обычно (и откатить через Ctrl+Z).
                </p>
                <textarea id="lime-doc-ai-prompt" class="lime-textarea" rows="5" maxlength="2000" style="width:100%;"
                          placeholder="Например: кофейня «Зерно» в Казани — обжариваем сами, доставка по городу, подписка на кофе…"></textarea>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-top: var(--space-3);">
                    <span class="lime-text-muted" id="lime-doc-ai-status" style="font-size: var(--text-xs);"></span>
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-ai-generate>Сгенерировать</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Media picker modal -->
    <div id="lime-media-modal" class="lime-modal-backdrop">
        <div class="lime-modal">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Выбери изображение</h3>
                <div class="lime-flex lime-gap-2 lime-items-center">
                    <label for="lime-media-upload" class="lime-btn lime-btn--soft lime-btn--sm" style="cursor:pointer;">+ Загрузить</label>
                    <input id="lime-media-upload" type="file" accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none;">
                    <button type="button" class="lime-modal__close" data-lime-modal-close aria-label="Закрыть">×</button>
                </div>
            </div>
            <div class="lime-modal__body">
                <div class="lime-flex lime-gap-2" style="margin-bottom: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--soft lime-btn--sm is-active" data-media-tab="mine">Мои</button>
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-media-tab="stock">Сток (фото)</button>
