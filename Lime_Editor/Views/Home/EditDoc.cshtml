                <div id="lime-media-status" class="lime-text-muted" style="display:none; margin-bottom: var(--space-3);"></div>
                <div id="lime-media-grid" class="lime-picker-grid">
                    <div class="lime-text-muted">Загрузка...</div>
                </div>
            </div>
        </div>
