@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@model ConstructorViewModel
@{
    Layout = null;
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var isEdit = Model.SiteId.HasValue;
    // Защита от закрытия </script> в пользовательском контенте при инлайне JSON.
    var seedJson = (Model.DocumentJson ?? "null").Replace("</", "<\\/");
    // Стартовый шаблон (Фаза 3.2) — только для нового документа; ключ санитайзим.
    var templateKey = isEdit ? "" : System.Text.RegularExpressions.Regex.Replace(
        Context.Request.Query["template"].ToString() ?? "", "[^a-zA-Z0-9_-]", "");
    // Раскатка Editor V2: дефолт нового редактора (Editor:V2Default, по умолчанию true).
    var v2DefaultCfg = Config["Editor:V2Default"];
    var v2Default = v2DefaultCfg == null || !v2DefaultCfg.Equals("false", StringComparison.OrdinalIgnoreCase);
}<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="X-CSRF-TOKEN" content="@csrfToken">
    <title>Конструктор · Lime</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&family=Unbounded:wght@400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800&family=Onest:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/lime/tokens.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/base.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/components.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/lime/constructor.css" asp-append-version="true">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js" defer></script>
    <script>
        window.__LIME_DOC__ = @Html.Raw(seedJson);
        window.__LIME_DOC_VERSION__ = @Model.DocVersion; // Site.UpdatedAt.Ticks — optimistic concurrency
        window.__LIME_TEMPLATE__ = @Html.Raw(string.IsNullOrEmpty(templateKey) ? "null" : "\"" + templateKey + "\"");
        // Раскатка Editor V2: дефолт нового редактора задаётся сервером (Editor:V2Default).
        window.__LIME_V2_DEFAULT__ = @(v2Default ? "true" : "false");
    </script>
</head>
<body>
    <div class="lime-editor">
        <div class="lime-editor__topbar">
            <div class="lime-editor__topbar-left">
                <a class="lime-editor__mark" href="/Home/MySites" title="К моим сайтам" aria-label="К моим сайтам">L</a>
                <span class="lime-text-muted" style="font-size: var(--text-sm);">@Model.SiteName</span>
                <span class="lime-badge lime-badge--accent">@(isEdit ? "редактор" : "черновик")</span>
            </div>
            <div class="lime-editor__topbar-center">
                <div class="lime-flex lime-gap-2" style="margin-right: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-doc-undo disabled title="Отменить (Ctrl+Z)">↶</button>
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-doc-redo disabled title="Вернуть (Ctrl+Shift+Z)">↷</button>
                </div>
                <div class="lime-device-toggle">
                    <button type="button" class="lime-device-toggle__btn is-active" data-doc-bp="base" title="Десктоп">🖥</button>
                    <button type="button" class="lime-device-toggle__btn" data-doc-bp="tablet" title="Планшет">📊</button>
                    <button type="button" class="lime-device-toggle__btn" data-doc-bp="mobile" title="Мобайл">📱</button>
                </div>
                <div class="lime-canvas-zoom" data-canvas-controls hidden>
                    <button type="button" data-canvas-zoom-out title="Уменьшить">−</button>
                    <button type="button" data-canvas-zoom-label title="100%">100%</button>
                    <button type="button" data-canvas-zoom-in title="Увеличить">+</button>
                    <button type="button" data-canvas-fit title="Вместить страницу">Fit</button>
                </div>
            </div>
            <div class="lime-editor__topbar-right">
                <span class="lime-text-muted" data-doc-status style="font-size: var(--text-xs); margin-right: var(--space-2);"></span>
                <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm lime-cmdk-btn" data-doc-cmdk title="Команды и поиск (Ctrl+K)" aria-keyshortcuts="Control+K"><span>Команды</span><kbd>⌘K</kbd></button>
                @if (Model.HasOriginalBackup)
                {
                    <form method="post" action="/Home/RestoreOriginal" style="display:inline;"
                          onsubmit="return confirm('Восстановить сайт к исходному виду до правок в новом редакторе? Текущий черновик будет заменён.');">
                        <input type="hidden" name="__RequestVerificationToken" value="@csrfToken" />
                        <input type="hidden" name="siteId" value="@Model.SiteId" />
                        <button type="submit" class="lime-btn lime-btn--ghost lime-btn--sm" title="Откатить к версии до перехода на новый редактор">↩ Оригинал</button>
                    </form>
                }
                <div class="lime-topbar-more" data-topbar-more>
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm lime-btn--icon" data-topbar-more-toggle aria-haspopup="menu" aria-expanded="false" title="Ещё действия">⋯</button>
                    <div class="lime-topbar-more__menu" role="menu" hidden>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-ai-open title="Сгенерировать страницу по описанию">✨ AI заново</button>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-theme-open title="Тема сайта">🎨 Тема сайта</button>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-code-open title="Глобальный CSS и код в head">&lt;/&gt; Код сайта</button>
                        <button type="button" class="lime-topbar-more__item" role="menuitem" data-doc-anim-preview title="Проиграть анимации появления">▶ Превью анимаций</button>
                    </div>
                </div>
                <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-save data-site-id="@(Model.SiteId?.ToString() ?? "")">
                    @(isEdit ? "Обновить" : "Опубликовать")
                </button>
            </div>
        </div>

        <aside class="lime-editor__sidebar">
            <div class="lime-editor__sidebar-section">
                <h3>Блоки</h3>
                <input type="search" id="lime-block-search" class="lime-sidebar-search" placeholder="Поиск блока…" autocomplete="off">
                <details class="lime-tile-group" open>
                    <summary>Структура</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="navbar"><span class="lime-block-tile__icon">≣</span><span>Навбар</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="footer"><span class="lime-block-tile__icon">▭</span><span>Подвал</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="container"><span class="lime-block-tile__icon">▣</span><span>Контейнер</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="columns"><span class="lime-block-tile__icon">⫼</span><span>Колонки</span></button>
                    </div>
                </details>
                <details class="lime-tile-group" open>
                    <summary>Контент</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="cover"><span class="lime-block-tile__icon">▢</span><span>Обложка</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="heading"><span class="lime-block-tile__icon">T</span><span>Заголовок</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="text"><span class="lime-block-tile__icon">¶</span><span>Текст</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="features"><span class="lime-block-tile__icon">✦</span><span>Фичи</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="stats"><span class="lime-block-tile__icon">#</span><span>Цифры</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="steps"><span class="lime-block-tile__icon">⇉</span><span>Шаги</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="testimonials"><span class="lime-block-tile__icon">❝</span><span>Отзывы</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="accordion"><span class="lime-block-tile__icon">▾</span><span>FAQ</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="logos"><span class="lime-block-tile__icon">◫</span><span>Логотипы</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="imageText"><span class="lime-block-tile__icon">◧</span><span>Картинка+текст</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="collectionList"><span class="lime-block-tile__icon">🗃</span><span>Список (данные)</span></button>
                    </div>
                </details>
                <details class="lime-tile-group">
                    <summary>Медиа</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="image"><span class="lime-block-tile__icon">🖼</span><span>Картинка</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="gallery"><span class="lime-block-tile__icon">▦</span><span>Галерея</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="video"><span class="lime-block-tile__icon">▶</span><span>Видео</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="embed"><span class="lime-block-tile__icon">◈</span><span>3D / Embed</span></button>
                    </div>
                </details>
                <details class="lime-tile-group">
                    <summary>Конверсия</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="cta"><span class="lime-block-tile__icon">◉</span><span>Призыв</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="form"><span class="lime-block-tile__icon">✉</span><span>Форма</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="pricing"><span class="lime-block-tile__icon">₽</span><span>Тарифы</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="buttonGroup"><span class="lime-block-tile__icon">⬚</span><span>Кнопки</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="socials"><span class="lime-block-tile__icon">@@</span><span>Соцсети</span></button>
                    </div>
                </details>
                <details class="lime-tile-group">
                    <summary>Разметка</summary>
                    <div class="lime-editor__tiles">
                        <button type="button" class="lime-block-tile" data-doc-add="divider"><span class="lime-block-tile__icon">—</span><span>Разделитель</span></button>
                        <button type="button" class="lime-block-tile" data-doc-add="spacer"><span class="lime-block-tile__icon">↕</span><span>Отступ</span></button>
                    </div>
                </details>
            </div>
            <div class="lime-editor__sidebar-section">
                <h3>Готовые секции</h3>
                <div id="lime-doc-presets" class="lime-editor__tiles"></div>
            </div>
            <div class="lime-editor__sidebar-section">
                <h3>Слои</h3>
                <div id="lime-doc-layers" class="lime-doc-layers"></div>
            </div>

            <div class="lime-editor__sidebar-section">
                <h3>Компоненты</h3>
                <div id="lime-doc-components"></div>
            </div>

            <div class="lime-editor__sidebar-section">
                <div class="lime-editor__hint">
                    <b>Совет.</b> Опиши идею через <b>✨ AI заново</b> — Lime соберёт блоки сам. Стили правятся для выбранного устройства, текст — прямо в блоке.
                </div>
            </div>
        </aside>

        <main class="lime-editor__canvas">
            <div id="lime-doc-pages" class="lime-doc-pages-bar"></div>
            <div id="lime-canvas-viewport" class="lime-canvas-viewport" role="group" aria-label="Холст редактора">
                <div id="lime-doc-workspace" class="lime-workspace" data-device="desktop"></div>
                <div id="lime-selection-overlay" class="lime-selection-overlay" aria-hidden="true">
                    <div data-selection-boxes></div>
                    <div class="lime-selection-hover" data-selection-hover hidden></div>
                    <div class="lime-selection-marquee" data-selection-marquee hidden></div>
                </div>
            </div>

            <!-- Intro overlay (показывается на пустом документе) -->
            <div class="lime-le-intro" id="lime-doc-intro">
                <div class="lime-le-prompt">
                    <div class="lime-le-prompt__eyebrow">✨ AI-конструктор</div>
                    <h2 class="lime-le-prompt__title">Опиши сайт — соберём за минуту</h2>
                    <p class="lime-le-prompt__sub">Одно-два предложения о бизнесе или проекте. Lime подберёт структуру, тексты и палитру, а блоки появятся прямо на холсте.</p>
                    <textarea class="lime-le-prompt__input" id="lime-doc-intro-prompt" maxlength="2000"
                              placeholder="Например: кофейня «Зерно» в Казани — обжариваем сами, доставка по городу, подписка на кофе…"></textarea>
                    <div class="lime-le-chips" id="lime-doc-intro-chips">
                        <button type="button" class="lime-le-chip">Кофейня с доставкой</button>
                        <button type="button" class="lime-le-chip">Студия дизайна</button>
                        <button type="button" class="lime-le-chip">Личный бренд-коуч</button>
                        <button type="button" class="lime-le-chip">SaaS для команд</button>
                    </div>
                    <div class="lime-le-prompt__foot">
                        <span class="lime-le-prompt__hint">⌘/Ctrl + Enter — создать</span>
                        <div class="lime-flex lime-gap-2">
                            <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" id="lime-doc-intro-skip">Собрать вручную</button>
                            <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" id="lime-doc-intro-go">Создать сайт →</button>
                        </div>
                    </div>
                    <div class="lime-le-prompt__msg" id="lime-doc-intro-msg"></div>
                </div>
            </div>
        </main>

        <aside class="lime-editor__inspector" id="lime-doc-inspector">
            <div class="lime-inspector__empty">Выбери блок в холсте, чтобы редактировать его стили.</div>
        </aside>
    </div>

    <!-- AI generation status pill + toast -->
    <div class="lime-le-status" id="lime-doc-le-status">
        <span class="lime-le-spinner" id="lime-doc-le-spinner"></span>
        <span class="lime-le-status__text" id="lime-doc-le-status-text">Разбираю запрос…</span>
    </div>
    <div class="lime-le-toast" id="lime-doc-le-toast"><b>✓ Сайт готов.</b> Можно править блоки.</div>

    <!-- Theme (тема сайта) modal -->
    <div id="lime-doc-theme-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 440px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Тема сайта</h3>
                <button type="button" class="lime-modal__close" data-doc-theme-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-3);">
                    Токены применяются ко всему сайту. Поменяешь раз — обновится везде, где блок ссылается на токен (свотчи под цветами в инспекторе).
                </p>
                <label style="display:block; font-size: var(--text-xs); color: var(--muted); margin-bottom: 6px;">Готовые палитры</label>
                <div id="lime-theme-palettes" class="lime-theme-palettes"></div>
                <div style="height:1px; background: var(--line); margin: var(--space-3) 0;"></div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Акцент</span>
                    <input type="color" id="lime-theme-accent" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Акцент 2</span>
                    <input type="color" id="lime-theme-accent2" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Фон сайта</span>
                    <input type="color" id="lime-theme-bg" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-2);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Текст</span>
                    <input type="color" id="lime-theme-fg" class="lime-color-input">
                </div>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-bottom: var(--space-3);">
                    <span class="lime-text-muted" style="font-size: var(--text-sm);">Приглушённый</span>
                    <input type="color" id="lime-theme-muted" class="lime-color-input">
                </div>
                <label style="display:block; font-size: var(--text-xs); color: var(--muted); margin-bottom: 4px;">Шрифт</label>
                <select id="lime-theme-font" class="lime-select" style="width:100%;">
                    <option value="'Inter', system-ui, sans-serif">Inter</option>
                    <option value="'Space Grotesk', system-ui, sans-serif">Space Grotesk</option>
                    <option value="'Manrope', system-ui, sans-serif">Manrope</option>
                    <option value="'Unbounded', system-ui, sans-serif">Unbounded (дисплейный)</option>
                    <option value="'Montserrat', system-ui, sans-serif">Montserrat</option>
                    <option value="'Onest', system-ui, sans-serif">Onest</option>
                    <option value="'Instrument Serif', Georgia, serif">Instrument Serif</option>
                    <option value="system-ui, -apple-system, sans-serif">Системный</option>
                    <option value="Georgia, 'Times New Roman', serif">Georgia</option>
                </select>
                <div class="lime-flex lime-gap-2" style="justify-content:flex-end; margin-top: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-theme-close>Готово</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Менеджер страниц (этап 0.3) -->
    <div id="lime-doc-pages-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 560px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Страницы сайта</h3>
                <button type="button" class="lime-modal__close" data-doc-pages-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-3);">
                    Первая страница — главная (адрес сайта). У остальных адрес = слаг: <code>/u/user/slug/страница</code>.
                </p>
                <div id="lime-doc-pages-list"></div>
                <button type="button" class="lime-btn lime-btn--soft lime-btn--sm" data-doc-page-add-modal style="margin-top: var(--space-3);">＋ Добавить страницу</button>
            </div>
        </div>
    </div>

    <!-- Код сайта (этап 0.2): глобальный CSS + кастомный head -->
    <div id="lime-doc-code-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 640px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">&lt;/&gt; Код сайта</h3>
                <button type="button" class="lime-modal__close" data-doc-code-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <label style="display:block; font-size: var(--text-xs); color: var(--muted); margin-bottom: 6px;">
                    Глобальный CSS <span class="lime-text-muted">— применяется ко всему сайту, идёт после стилей блоков (может их перебить)</span>
                </label>
                <textarea id="lime-doc-custom-css" class="lime-textarea" rows="8" spellcheck="false"
                          style="width:100%; font-family: var(--font-mono, monospace); font-size: var(--text-sm);"
                          placeholder=".lime-block__heading { letter-spacing: -.02em }&#10;a { transition: color .2s }"></textarea>
                <label style="display:block; font-size: var(--text-xs); color: var(--muted); margin: var(--space-3) 0 6px;">
                    Код в &lt;head&gt; <span class="lime-text-muted">— мета-теги, верификации, шрифты, &lt;link&gt;/&lt;style&gt;</span>
                </label>
                <textarea id="lime-doc-custom-head" class="lime-textarea" rows="6" spellcheck="false"
                          style="width:100%; font-family: var(--font-mono, monospace); font-size: var(--text-sm);"
                          placeholder='&lt;meta name="yandex-verification" content="..."&gt;&#10;&lt;link rel="stylesheet" href="https://..."&gt;'></textarea>
                <div class="lime-editor__hint" style="margin-top: var(--space-2);">
                    В целях безопасности &lt;script&gt; в head пока вырезается на публикации (разблокируется после выноса публикаций на отдельный домен). Разрешены meta, link, style.
                </div>
                <div class="lime-flex lime-gap-2" style="justify-content:flex-end; margin-top: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-code-close>Готово</button>
                </div>
            </div>
        </div>
    </div>

    <!-- AI modal (описание бизнеса → блоки) -->
    <div id="lime-doc-ai-modal" class="lime-modal-backdrop">
        <div class="lime-modal" style="max-width: 560px;">
            <div class="lime-modal__head">
                <h3 style="margin:0;">✨ Сгенерировать страницу</h3>
                <button type="button" class="lime-modal__close" data-doc-ai-close aria-label="Закрыть">×</button>
            </div>
            <div class="lime-modal__body">
                <p class="lime-text-muted" style="font-size: var(--text-xs); margin-bottom: var(--space-3);">
                    Опиши бизнес или проект — AI соберёт лендинг из блоков конструктора прямо на активной странице.
                    Потом всё можно править как обычно (и откатить через Ctrl+Z).
                </p>
                <textarea id="lime-doc-ai-prompt" class="lime-textarea" rows="5" maxlength="2000" style="width:100%;"
                          placeholder="Например: кофейня «Зерно» в Казани — обжариваем сами, доставка по городу, подписка на кофе…"></textarea>
                <div class="lime-flex lime-items-center" style="justify-content: space-between; margin-top: var(--space-3);">
                    <span class="lime-text-muted" id="lime-doc-ai-status" style="font-size: var(--text-xs);"></span>
                    <button type="button" class="lime-btn lime-btn--primary lime-btn--sm" data-doc-ai-generate>Сгенерировать</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Media picker modal -->
    <div id="lime-media-modal" class="lime-modal-backdrop">
        <div class="lime-modal">
            <div class="lime-modal__head">
                <h3 style="margin:0;">Выбери изображение</h3>
                <div class="lime-flex lime-gap-2 lime-items-center">
                    <label for="lime-media-upload" class="lime-btn lime-btn--soft lime-btn--sm" style="cursor:pointer;">+ Загрузить</label>
                    <input id="lime-media-upload" type="file" accept=".jpg,.jpeg,.png,.gif,.webp" style="display:none;">
                    <button type="button" class="lime-modal__close" data-lime-modal-close aria-label="Закрыть">×</button>
                </div>
            </div>
            <div class="lime-modal__body">
                <div class="lime-flex lime-gap-2" style="margin-bottom: var(--space-3);">
                    <button type="button" class="lime-btn lime-btn--soft lime-btn--sm is-active" data-media-tab="mine">Мои</button>
                    <button type="button" class="lime-btn lime-btn--ghost lime-btn--sm" data-media-tab="stock">Сток (фото)</button>
                </div>
                <form id="lime-stock-search" style="display:none; margin-bottom: var(--space-3);">
                    <div class="lime-flex lime-gap-2">
                        <input id="lime-stock-q" type="text" placeholder="Поиск фото: coffee, office, nature…"
                               style="flex:1; padding:8px 12px; border:1px solid var(--line); border-radius: var(--radius-md); background: var(--ink-2); color: var(--fg);">
                        <button type="submit" class="lime-btn lime-btn--primary lime-btn--sm">Найти</button>
                    </div>
                    <div class="lime-text-muted" style="font-size: var(--text-xs); margin-top: 6px;">Фото с Pexels. По клику вставляется по прямой ссылке.</div>
                </form>
                <div id="lime-media-status" class="lime-text-muted" style="display:none; margin-bottom: var(--space-3);"></div>
                <div id="lime-media-grid" class="lime-picker-grid">
                    <div class="lime-text-muted">Загрузка...</div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js" defer></script>
    <script src="~/js/lime/lime-animate.js" asp-append-version="true" defer></script>
    <script src="~/js/lime/lime-assets.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-fonts.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-presets.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-templates.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-doc.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-design.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-viewport.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-selection.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-layout.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-snap.js" asp-append-version="true"></script>
    @* Editor V2 (D2): command-system + история. Активируется флагом ?cmd=1 в URL редактора. *@
    <script src="~/js/lime/lime-commands.js" asp-append-version="true"></script>
    <script src="~/js/lime/lime-doc-editor.js" asp-append-version="true" defer></script>
</body>
</html>
