@model ProfileViewModel
@{
    ViewData["Title"] = "Личный кабинет";
    var initial = string.IsNullOrEmpty(Model.Login) ? "?" : Model.Login.Substring(0, 1).ToUpper();
    var fullName = $"{Model.Name} {Model.LastName}".Trim();
}

<section class="lime-aurora lime-aurora--subtle" style="padding: var(--space-12) 0 var(--space-8);">
    <div class="lime-container">
        <div class="lime-profile">
            <div class="lime-profile__head">
                <span class="lime-avatar lime-avatar--lg" aria-hidden="true">@initial</span>
                <div>
                    <div class="lime-profile__name">@(string.IsNullOrEmpty(fullName) ? Model.Login : fullName)</div>
                    <div class="lime-profile__email">@Model.Email</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="lime-container" style="padding-bottom: var(--space-16);">
    <div class="lime-profile">
        <div class="lime-card lime-card--padded">
            <h3 style="margin-bottom: var(--space-2);">Профиль</h3>
            <p class="lime-text-muted lime-mb-6">Эти данные видны только тебе.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                var errors = ViewData.ModelState
                    .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                    .Where(s => !string.IsNullOrEmpty(s)).ToList();
                if (errors.Count > 0)
                {
                    <div class="lime-alert lime-alert--danger lime-mb-4">
                        @foreach (var e in errors) { <div>@e</div> }
                    </div>
                }
            }

            <form asp-action="EditProfile" asp-controller="Home" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="lime-grid lime-gap-4" style="grid-template-columns: 1fr 1fr;">
                    <div class="lime-field">
                        <label class="lime-label" for="p-name">Имя</label>
                        <input id="p-name" class="lime-input" asp-for="Name" placeholder="Имя">
                    </div>
                    <div class="lime-field">
                        <label class="lime-label" for="p-lastname">Фамилия</label>
                        <input id="p-lastname" class="lime-input" asp-for="LastName" placeholder="Фамилия">
                    </div>
                    <div class="lime-field">
                        <label class="lime-label" for="p-login">Логин</label>
                        <input id="p-login" class="lime-input" asp-for="Login" required pattern="[A-z0-9.]{2,50}">
                        <span asp-validation-for="Login" class="lime-validation"></span>
                    </div>
                    <div class="lime-field">
                        <label class="lime-label" for="p-email">Email</label>
                        <input id="p-email" class="lime-input" asp-for="Email" type="email" required>
                        <span asp-validation-for="Email" class="lime-validation"></span>
                    </div>
                </div>
                <hr>
                <div class="lime-field" style="max-width: 360px;">
                    <label class="lime-label" for="p-password">Новый пароль <span class="lime-text-subtle">(необязательно)</span></label>
                    <input id="p-password" class="lime-input" asp-for="Password" type="password" autocomplete="new-password" minlength="6" placeholder="Оставь пустым чтобы не менять">
                    <span class="lime-help">Минимум 6 символов.</span>
                </div>

                <div class="lime-flex lime-gap-2 lime-mt-6">
                    <button type="submit" class="lime-btn lime-btn--primary">Сохранить</button>
                    <a class="lime-btn lime-btn--ghost" href="/Home/MySites">Отмена</a>
                </div>
            </form>
        </div>

        <div class="lime-card lime-card--padded lime-mt-4">
            <h3 style="margin-bottom: var(--space-2);">Опасная зона</h3>
            <p class="lime-text-muted lime-mb-4">Удаление аккаунта в текущей версии недоступно. Свяжись через GitHub.</p>
            <a class="lime-btn lime-btn--ghost" href="/Home/Logout">Выйти из аккаунта</a>
        </div>
    </div>
</section>
