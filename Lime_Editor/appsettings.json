{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": { "connect": "" },
  // Host-header allow-list. Fail-closed дефолт: только localhost. Прод задаёт реальный домен
  // через env (AllowedHosts=${DOMAIN} в compose.prod.yml), dev разрешает всё через
  // appsettings.Development.json. Так публичный инстанс не отвечает на чужой Host (защита от
  // host-header-инъекций/кэш-отравления), а локальная разработка не страдает.
  "AllowedHosts": "localhost",
  "Identity": {
    // Требовать подтверждённый email для входа. Включать в true ТОЛЬКО после подключения
    // боевого SMTP (env SMTP_*), иначе пользователи не смогут войти (письма уходят в лог).
    "RequireConfirmedEmail": false
  },
  // Хранилище загруженных медиа. "local" (дефолт) — wwwroot/media на диске приложения.
  // Для прода переключается на S3-совместимое (AWS S3 / Cloudflare R2 / MinIO) БЕЗ правок кода:
  //   "MediaStorage": {
  //     "Provider": "s3",
  //     "S3": {
  //       "Bucket": "lime-media",
  //       "PublicBaseUrl": "https://media.example.com",   // публичный домен бакета/CDN
  //       "ServiceUrl": "https://<account>.r2.cloudflarestorage.com", // R2/MinIO; пусто = AWS по Region
  //       "Region": "eu-central-1"                        // только для родного AWS
  //     }
  //   }
  // Ключи — ТОЛЬКО через env: S3_ACCESS_KEY, S3_SECRET_KEY (или MediaStorage:S3:AccessKey/SecretKey).
  "MediaStorage": { "Provider": "local" },
  "Ai": {
    // OpenAI-совместимый агрегатор (VseGPT/OpenRouter/ProxyAPI-openai и т.п.).
    // Ключ и base-url — ТОЛЬКО через env: AI_API_KEY, AI_BASE_URL (см. .env.example).
    // Модель — слаг агрегатора; проверь, что у провайдера есть именно этот id.
    // Haiku 4.5 — самый дешёвый дефолт для free-пользователей.
    // Платные тарифы (этап 3.4): "anthropic/claude-sonnet-4-6" / "anthropic/claude-opus-4-8".
    "Model": "anthropic/claude-haiku-4-5",
    "MonthlyFreeQuota": 10,
    "MaxTokens": 4000
  }
}
